<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <%- include('css') %>
</head>

<body>
    <%- include('header') %>

        <div class="table-card">
            <form action="/tkb/them" method="POST">
                <div class="row">
                    <div class="col-md-12 mb-4">
                        <label class="form-label"><i class="fas fa-book me-2 text-info"></i>Môn Học</label>
                        <select name="MonHoc" class="form-select shadow-sm" required>
                            <option value="" selected disabled>-- Chọn môn học từ danh sách --</option>
                            <% dsmon.forEach(mon=> { %>
                                <option value="<%= mon._id %>">
                                    <%= mon.TenMonHoc %>
                                </option>
                                <% }) %>
                        </select>
                        <small class="text-muted ms-2">Dữ liệu được lấy từ danh mục Môn học</small>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label"><i class="fas fa-user-tie me-2 text-success"></i>Giảng Viên</label>
                        <select name="GiangVien" class="form-select shadow-sm" required>
                            <option value="" selected disabled>-- Chọn giảng viên --</option>
                            <% dsgiangvien.forEach(gv=> { %>
                                <option value="<%= gv._id %>">
                                    <%= gv.HoVaTen %>
                                </option>
                                <% }) %>
                        </select>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label"><i class="fas fa-users me-2 text-warning"></i>Lớp Học</label>
                        <select name="LopHoc" class="form-select shadow-sm" required>
                            <option value="" selected disabled>-- Chọn lớp học --</option>
                            <% dslop.forEach(lop=> { %>
                                <option value="<%= lop._id %>">
                                    <%= lop.TenLop %>
                                </option>
                                <% }) %>
                        </select>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label"><i class="fas fa-map-marker-alt me-2 text-danger"></i>Phòng
                            Học</label>
                        <select name="PhongHoc" class="form-control shadow-sm" required>
                            <option value="" selected disabled>-- Chọn phòng --</option>
                            <% dsphong.forEach(p=> { %>
                                <option value="<%= p._id %>">
                                    <%= p.TenPhong %> (<%= p.LoaiPhong %> - Sức chứa: <%= p.SucChua %>)
                                </option>
                                <% }) %>
                        </select>
                    </div>

                    <div class="col-md-3 mb-4">
                        <label class="form-label"><i class="fas fa-hashtag me-2 text-primary"></i>Tuần Học</label>
                        <select name="Tuan" class="form-select shadow-sm" required>
                            <% weeks.forEach(function(w) { %>
                                <option value="<%= w.number %>" <%=currentWeek==w.number ? 'selected' : '' %>>
                                    <%= w.label %>
                                </option>
                                <% }); %>
                        </select>
                    </div>

                    <div class="col-md-3 mb-4">
                        <label class="form-label">Thứ</label>
                        <select name="Thu" class="form-select shadow-sm">
                            <% ["Thứ 2", "Thứ 3" , "Thứ 4" , "Thứ 5" , "Thứ 6" , "Thứ 7" , "Chủ Nhật" ].forEach(thu=> {
                                %>
                                <option value="<%= thu %>">
                                    <%= thu %>
                                </option>
                                <% }) %>
                        </select>
                    </div>

                    <div class="col-md-3 mb-4">
                        <label class="form-label">Tiết Bắt Đầu</label>
                        <input type="number" name="TietBatDau" min="1" max="12" class="form-control" required>
                    </div>

                    <div class="col-md-3 mb-4">
                        <label class="form-label">Tiết Kết Thúc</label>
                        <input type="number" name="TietKetThuc" min="1" max="12" class="form-control" required>
                    </div>

                    <div class="col-12 text-center mt-4">
                        <button type="submit" class="btn main-btn px-5 shadow">
                            <i class="fas fa-magic me-2"></i>Tạo buổi học ngay
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>