<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <%- include('css') %>
</head>

<body>
    <%- include('header') %>

        <div class="container mt-5 mb-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-dark mb-1">Quản Lý Môn Học</h2>
                    <p class="text-muted mb-0">Hệ thống hóa chương trình đào tạo của Edu KT</p>
                </div>
                <a href="/monhoc/them" class="btn main-btn shadow-sm">
                    <i class="fas fa-plus-circle me-2"></i>Thêm môn học mới
                </a>
            </div>

            <div class="table-card shadow-sm border-0" style="border-radius: 15px; overflow: hidden; background: #fff;">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead style="background-color: #f8f9fa;">
                            <tr class="text-secondary">
                                <th class="ps-4 py-3" style="width: 80px;">STT</th>
                                <th class="py-3">Mã Môn</th>
                                <th class="py-3">Tên Môn Học</th>
                                <th class="py-3 text-center">Tín Chỉ</th>
                                <th class="py-3">Mô Tả</th>
                                <th class="py-3 text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(dsMonHoc && dsMonHoc.length> 0) { %>
                                <% var stt=1; %>
                                    <% dsMonHoc.forEach(mon=> { %>
                                        <tr>
                                            <td class="ps-4 fw-bold text-muted">
                                                <%= stt++ %>
                                            </td>
                                            <td>
                                                <span class="px-2 py-1 bg-light rounded text-primary fw-600"
                                                    style="font-size: 0.85em; border: 1px solid #e9ecef;">
                                                    <%= mon.MaMonHoc %>
                                                </span>
                                            </td>
                                            <td>
                                                <div class="fw-bold text-dark">
                                                    <%= mon.TenMonHoc %>
                                                </div>
                                                <div class="small text-muted" style="font-size: 0.75rem;">
                                                    ID: <%= mon._id.toString().substring(18) %>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <div class="d-flex flex-column align-items-center">
                                                    <span
                                                        class="badge rounded-pill bg-warning-subtle text-warning-emphasis px-3">
                                                        <i class="fas fa-star me-1"></i>
                                                        <%= mon.SoTinChi %> tín chỉ
                                                    </span>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="text-truncate text-muted" style="max-width: 250px;"
                                                    title="<%= mon.MoTa %>">
                                                    <%= mon.MoTa || 'Chưa có mô tả chi tiết...' %>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <div class="d-flex justify-content-center gap-2">
                                                    <a href="/monhoc/sua/<%= mon._id %>"
                                                        class="btn btn-sm btn-light rounded-circle text-primary border shadow-sm btn-action-hover"
                                                        title="Chỉnh sửa">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a href="/monhoc/xoa/<%= mon._id %>"
                                                        class="btn btn-sm btn-light rounded-circle text-danger border shadow-sm btn-action-hover"
                                                        onclick="return confirm('Tâm ơi, xóa môn này là không hoàn tác được đâu, em chắc chứ?')"
                                                        title="Xóa môn">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="6" class="text-center py-5 text-muted">
                                                        <i class="fas fa-book-open fa-3x mb-3 opacity-20"></i>
                                                        <p>Ngọc Tâm ơi, danh sách môn học đang trống trải quá!</p>
                                                    </td>
                                                </tr>
                                                <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <%- include('footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>

<style>
    /* Style này được anh kế thừa từ style trang Lớp học của Tâm nè */
    body {
        font-family: 'Quicksand', sans-serif;
        background-color: #f4f7f6;
    }

    .main-btn {
        background: linear-gradient(135deg, #17a2b8 0%, #007bff 100%);
        /* Anh đổi tone xanh teal cho khác lớp học xíu nhé */
        color: white;
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        transition: 0.3s;
    }

    .main-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 123, 255, 0.3);
        color: white;
    }

    .table-card {
        background: #fff;
        border-radius: 15px;
    }

    .fw-600 {
        font-weight: 600;
    }

    .btn-action-hover:hover {
        background-color: #f8f9fa !important;
        transform: scale(1.1);
        transition: 0.2s;
    }

    .table-responsive::-webkit-scrollbar {
        height: 6px;
    }

    .table-responsive::-webkit-scrollbar-thumb {
        background: #dee2e6;
        border-radius: 10px;
    }
</style>