<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            font-family: 'Quicksand', sans-serif;
            background-color: #f8f9fa;
        }

        .hero-banner {
            /* Điều chỉnh khoảng cách phần banner để nội dung nằm gọn trong màn hình. */
            padding: 40px 0 20px 0;
            background: radial-gradient(circle at top right, #e3f2fd, #ffffff);

            /* Kéo banner lên nhẹ để cân bằng bố cục. */
            margin-top: -10px;
        }

        .main-btn {
            background: linear-gradient(135deg, #007bff 0%, #6610f2 100%);
            border: none;
            color: white;
            padding: 10px 30px;
            /* Giữ nút vừa đủ nổi bật nhưng không chiếm quá nhiều diện tích. */
            border-radius: 50px;
            font-weight: 600;
            transition: 0.3s;
        }

        .main-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(0, 123, 255, 0.3);
            color: white;
        }

        .feature-box {
            border: none;
            border-radius: 20px;
            background: #ffffff;
            padding: 25px;
            /* Giảm nhẹ padding bên trong box */
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        .hero-banner h1 {
            font-size: 2.8rem;
            /* Giảm kích thước font một chút để không quá choán chỗ */
            margin-bottom: 15px;
        }

        .hero-banner h1 span {
            color: #007bff !important;
        }

        .hero-banner p {
            margin-bottom: 25px;
            /* Giảm khoảng cách dưới đoạn văn bản */
        }
    </style>
</head>

<body>
    <!-- Phần đầu   -->
    <%- include('header') %>

        <!-- Nội dung   -->
        <div class="container">

            <!-- Nội dung chính -->
            <div class="card mt-3">
                <div class="card-header">
                    <%= title %>
                </div>
                <div class="card-body">
                    <% if(typeof message !=="undefined" && message) { %>
                        <div class="alert alert-danger mb-0" role="alert">
                            <%- message %>
                        </div>
                        <% } %>
                </div>
            </div>


</body>

</html>
