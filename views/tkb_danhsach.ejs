<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <%- include('css') %>
        <style>
            body {
                font-family: 'Quicksand', sans-serif;
                background-color: #f4f7f6;
            }

            .table-card {
                background: white;
                border-radius: 20px;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
                border: none;
            }

            .main-btn {
                background: linear-gradient(135deg, #007bff 0%, #6610f2 100%);
                border: none;
                color: white;
                border-radius: 50px;
                font-weight: 600;
                padding: 10px 25px;
                transition: 0.3s;
            }

            .main-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(102, 16, 242, 0.3);
                color: white;
            }

            /* Hiệu ứng cho các nút tròn */
            .btn-circle {
                width: 34px;
                height: 34px;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: 0.3s;
            }

            .btn-circle:hover {
                transform: scale(1.15);
            }
        </style>
</head>

<body>
    <%- include('header') %>
        <div class="container mt-5 mb-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold">📅 Danh sách lịch học</h2>
                    <p class="text-muted">
                        Trạng thái:
                        <% if (dstkb && dstkb.length> 0) { %>
                            <% if (dstkb[0].TrangThai==='cho-duyet' ) { %>
                                <span class="text-warning fw-bold">Chờ duyệt</span>
                                <% } else { %>
                                    <span class="text-success fw-bold">Đã duyệt</span>
                                    <% } %>
                                        <% } else { %>
                                            <span class="text-muted fw-bold">Trống</span>
                                            <% } %>
                    </p>
                </div>
                <a href="/tkb/dangky" class="btn main-btn">
                    <i class="fas fa-plus-circle me-2"></i>Đăng ký thêm
                </a>
            </div>

            <div class="table-card overflow-hidden">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">STT</th>
                            <th>Môn Học</th>
                            <th>Lớp & Giảng Viên</th>
                            <th>Thời Gian</th>
                            <th>Phòng</th>
                            <th class="text-center">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% var stt=1; %>
                            <% dstkb.forEach(function(item) { %>
                                <tr id="row-<%= item._id %>">
                                    <td class="ps-4 text-muted fw-bold">
                                        <%= stt++ %>
                                    </td>
                                    <td class="fw-bold text-primary">
                                        <%= item.MonHoc ? item.MonHoc.TenMonHoc : 'Trống' %>
                                    </td>
                                    <td>
                                        <div>Lớp: <%= item.LopHoc ? item.LopHoc.TenLop : 'N/A' %>
                                        </div>
                                        <small class="text-muted"><i class="fas fa-user-tie me-1"></i>
                                            <%= item.GiangVien ? item.GiangVien.HoVaTen : 'N/A' %>
                                        </small>
                                    </td>
                                    <td>
                                        <strong class="text-dark">
                                            <%= item.Thu %>
                                        </strong><br>
                                        <small class="text-muted">Ca <%= item.CaHoc %> (Tiết <%= item.TietBatDau %>
                                                    )</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-info-subtle text-info px-3 py-2 rounded-pill">
                                            <i class="fas fa-door-open me-1"></i>
                                            <%= item.PhongHoc ? item.PhongHoc.TenPhong : 'N/A' %>
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <% if (item.TrangThai==='cho-duyet' ) { %>
                                                <button onclick="duyetLich( '<%= item._id %>')"
                                                    class="btn btn-sm btn-light rounded-circle text-success border shadow-sm btn-circle"
                                                    title="Phê duyệt">
                                                    <i class="fas fa-check"></i>
                                                </button>
                                                <% } %>

                                                    <a href="/tkb/sua/<%= item._id %>"
                                                        class="btn btn-sm btn-light rounded-circle text-primary border shadow-sm btn-circle"
                                                        title="Chỉnh sửa">
                                                        <i class="fas fa-edit"></i>
                                                    </a>

                                                    <a href="/tkb/xoa/<%= item._id %>"
                                                        class="btn btn-sm btn-light rounded-circle text-danger border shadow-sm btn-circle"
                                                        onclick="return confirm('Tâm có chắc muốn xóa không?')"
                                                        title="Xóa">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </a>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

        <script>
            async function duyetLich(id) {
                // 1. Hỏi ý kiến Tâm một lần nữa cho chắc
                if (!confirm("Tâm có chắc chắn muốn phê duyệt lịch học này không?")) return;

                try {
                    // 2. Gửi yêu cầu cập nhật lên Server
                    const response = await fetch(`/tkb/da-duyet/${id}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ status: 'da-duyet' })
                    });

                    // 3. Đợi Server trả về kết quả JSON
                    const data = await response.json();

                    if (response.ok && data.success) {
                        // 4. Hiệu ứng làm mờ và xóa dòng (Professional hơn)
                        const row = document.getElementById(`row-${id}`);
                        row.style.transition = "all 0.5s ease";
                        row.style.backgroundColor = "#d4edda"; // Tô màu xanh báo hiệu thành công
                        row.style.opacity = "0";

                        setTimeout(() => {
                            row.remove();
                            // Kiểm tra nếu không còn dòng nào thì tải lại trang để hiện thông báo trống
                            const remainingRows = document.querySelectorAll('tbody tr').length;
                            if (remainingRows === 0) {
                                location.reload();
                            }
                        }, 500);

                        console.log("Thông báo từ server:", data.message);
                    } else {
                        alert("Lỗi: " + (data.message || "Không thể duyệt lịch lúc này."));
                    }
                } catch (error) {
                    console.error("Lỗi kết nối:", error);
                    alert("Lỗi kết nối mạng rồi Tâm ơi, kiểm tra lại nhé!");
                }
            }
        </script>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>