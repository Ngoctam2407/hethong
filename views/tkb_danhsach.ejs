<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <%- include('css') %>
        <style>
            body {
                font-family: 'Quicksand', sans-serif;
                background-color: #f4f7f6;
            }

            .table-card {
                background: white;
                border-radius: 20px;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
                border: none;
            }

            .main-btn {
                background: linear-gradient(135deg, #007bff 0%, #6610f2 100%);
                border: none;
                color: white;
                border-radius: 50px;
                font-weight: 600;
                padding: 10px 25px;
                transition: 0.3s;
            }

            .main-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(102, 16, 242, 0.3);
                color: white;
            }

            /* Hiệu ứng cho các nút tròn */
            .btn-circle {
                width: 34px;
                height: 34px;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: 0.3s;
            }

            .btn-circle:hover {
                transform: scale(1.15);
            }
        </style>
</head>

<body>
    <% function formatDateTimeVN(dateValue) { if (!dateValue) return 'Chưa cập nhật' ; const d=new Date(dateValue); if
        (Number.isNaN(d.getTime())) return 'Chưa cập nhật' ; const pad=(n)=> String(n).padStart(2, '0');
        return `${pad(d.getDate())}/${pad(d.getMonth() + 1)}/${d.getFullYear()}
        ${pad(d.getHours())}:${pad(d.getMinutes())}`;
        }

        function getTrangThaiMeta(trangThai) {
        if (trangThai === 'da-duyet') {
        return { text: 'Đã duyệt', badgeClass: 'bg-success-subtle text-success' };
        }
        return { text: 'Chờ duyệt', badgeClass: 'bg-warning-subtle text-warning' };
        }
        %>
        <%- include('header') %>
            <div class="container mt-5 mb-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="fw-bold">Danh sách lịch học</h2>
                        <p class="text-muted">
                            Trạng thái:
                            <% if (dstkb && dstkb.length> 0) { %>
                                <% if (dstkb[0].TrangThai==='cho-duyet' ) { %>
                                    <span class="text-warning fw-bold">Chờ duyệt</span>
                                    <% } else { %>
                                        <span class="text-success fw-bold">Đã duyệt</span>
                                        <% } %>
                                            <% } else { %>
                                                <span class="text-muted fw-bold">Trống</span>
                                                <% } %>
                        </p>
                    </div>
                    <a href="/tkb/dangky" class="btn main-btn">
                        <i class="fas fa-plus-circle me-2"></i>Đăng ký thêm
                    </a>
                </div>

                <div class="table-card overflow-hidden">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">STT</th>
                                <th>Môn Học</th>
                                <th>Lớp & Giảng Viên</th>
                                <th>Thời Gian</th>
                                <th>Phòng</th>
                                <th class="text-center">Thao Tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% var stt=1; %>
                                <% dstkb.forEach(function(item) { %>
                                    <tr id="row-<%= item._id %>">
                                        <td class="ps-4 text-muted fw-bold">
                                            <%= stt++ %>
                                        </td>
                                        <td class="fw-bold text-primary">
                                            <%= item.MonHoc ? item.MonHoc.TenMonHoc : 'Trống' %>
                                        </td>
                                        <td>
                                            <div>Lớp: <%= item.LopHoc ? item.LopHoc.TenLop : 'N/A' %>
                                            </div>
                                            <small class="text-muted"><i class="fas fa-user-tie me-1"></i>
                                                <%= item.GiangVien ? item.GiangVien.HoVaTen : 'N/A' %>
                                            </small>
                                        </td>
                                        <td>
                                            <strong class="text-dark">
                                                <%= item.Thu %>
                                            </strong><br>
                                            <small class="text-muted">Ca <%= item.CaHoc %> (Tiết <%= item.TietBatDau %>
                                                        )</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-info-subtle text-info px-3 py-2 rounded-pill">
                                                <i class="fas fa-door-open me-1"></i>
                                                <%= item.PhongHoc ? item.PhongHoc.TenPhong : 'N/A' %>
                                            </span>
                                        </td>

                                        <td class="text-center">
                                            <% const trangThaiMeta=getTrangThaiMeta(item.TrangThai); %>
                                                <div class="d-flex justify-content-center gap-2">
                                                    <% if (item.TrangThai==='cho-duyet' ) { %>
                                                        <button onclick="duyetLich( '<%= item._id %>')"
                                                            class="btn btn-sm btn-light rounded-circle text-success border shadow-sm btn-circle"
                                                            title="Phê duyệt">
                                                            <i class="fas fa-check"></i>
                                                        </button>

                                                        <button onclick="tuChoiLich('<%= item._id %>')"
                                                            class="btn btn-sm btn-light rounded-circle text-danger border shadow-sm btn-circle"
                                                            title="Từ chối">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                        <% } %>

                                                            <button type="button"
                                                                class="btn btn-sm btn-light rounded-circle text-info border shadow-sm btn-circle"
                                                                title="Chi tiết" data-bs-toggle="modal"
                                                                data-bs-target="#chiTietDangKyModal"
                                                                data-mon-hoc="<%= item.MonHoc ? item.MonHoc.TenMonHoc : 'Trống' %>"
                                                                data-lop-hoc="<%= item.LopHoc ? item.LopHoc.TenLop : 'N/A' %>"
                                                                data-giang-vien="<%= item.GiangVien ? item.GiangVien.HoVaTen : 'N/A' %>"
                                                                data-phong-hoc="<%= item.PhongHoc ? item.PhongHoc.TenPhong : 'N/A' %>"
                                                                data-thoi-gian-hoc="<%= item.Thu %> - Ca <%= item.CaHoc %> (Tiết <%= item.TietBatDau %>-<%= item.TietKetThuc %>)"
                                                                data-ngay-dang-ky="<%= formatDateTimeVN(item.NgayDangKy) %>"
                                                                data-ngay-duyet="<%= formatDateTimeVN(item.NgayDuyet) %>"
                                                                data-trang-thai-text="<%= trangThaiMeta.text %>"
                                                                data-trang-thai-class="<%= trangThaiMeta.badgeClass %>">
                                                                <i class="fas fa-circle-info"></i>
                                                            </button>

                                                            <a href="/tkb/sua/<%= item._id %>"
                                                                class="btn btn-sm btn-light rounded-circle text-primary border shadow-sm btn-circle"
                                                                title="Chỉnh sửa">
                                                                <i class="fas fa-edit"></i>
                                                            </a>

                                                            <a href="/tkb/xoa/<%= item._id %>"
                                                                class="btn btn-sm btn-light rounded-circle text-danger border shadow-sm btn-circle"
                                                                onclick="return confirm('Tâm có chắc muốn xóa không?')"
                                                                title="Xóa">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </a>
                                                </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="modal fade" id="chiTietDangKyModal" tabindex="-1" aria-labelledby="chiTietDangKyModalLabel"
                aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg" style="border-radius: 18px;">
                        <div class="modal-header border-0 pb-0">
                            <div>
                                <h5 class="modal-title fw-bold" id="chiTietDangKyModalLabel">
                                    <i class="fas fa-file-circle-info text-info me-2"></i>Chi tiết đăng ký lịch học
                                </h5>
                                <p class="text-muted mb-0 small" id="modalMonHoc">Thông tin lịch học đã chọn</p>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body pt-3">
                            <div class="mb-3">
                                <div class="small text-muted">Lớp và giảng viên</div>
                                <div class="fw-semibold" id="modalLopGiangVien">-</div>
                            </div>
                            <div class="mb-3">
                                <div class="small text-muted">Buổi học</div>
                                <div class="fw-semibold" id="modalThoiGianHoc">-</div>
                            </div>
                            <div class="mb-3">
                                <div class="small text-muted">Phòng học</div>
                                <div class="fw-semibold" id="modalPhongHoc">-</div>
                            </div>
                            <div class="mb-3">
                                <div class="small text-muted">Thời gian đăng ký</div>
                                <div class="fw-semibold" id="modalNgayDangKy">-</div>
                            </div>
                            <div class="mb-3">
                                <div class="small text-muted">Thời gian duyệt</div>
                                <div class="fw-semibold" id="modalNgayDuyet">-</div>
                            </div>
                            <div>
                                <div class="small text-muted">Trạng thái hiện tại</div>
                                <span class="badge px-3 py-2 rounded-pill" id="modalTrangThai">-</span>
                            </div>
                        </div>
                        <div class="modal-footer border-0 pt-0">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                        </div>
                    </div>
                </div>
            </div>

            <script>
                async function duyetLich(id) {
                    // 1. Hỏi ý kiến Tâm một lần nữa cho chắc
                    if (!confirm("Tâm có chắc chắn muốn phê duyệt lịch học này không?")) return;

                    try {
                        // 2. Gửi yêu cầu cập nhật lên Server
                        const response = await fetch(`/tkb/da-duyet/${id}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ status: 'da-duyet' })
                        });

                        // 3. Đợi Server trả về kết quả JSON
                        const data = await response.json();

                        if (response.ok && data.success) {
                            // 4. Hiệu ứng làm mờ và xóa dòng (Professional hơn)
                            const row = document.getElementById(`row-${id}`);
                            row.style.transition = "all 0.5s ease";
                            row.style.backgroundColor = "#d4edda"; // Tô màu xanh báo hiệu thành công
                            row.style.opacity = "0";

                            setTimeout(() => {
                                row.remove();
                                // Kiểm tra nếu không còn dòng nào thì tải lại trang để hiện thông báo trống
                                const remainingRows = document.querySelectorAll('tbody tr').length;
                                if (remainingRows === 0) {
                                    location.reload();
                                }
                            }, 500);

                            console.log("Thông báo từ server:", data.message);
                        } else {
                            alert("Lỗi: " + (data.message || "Không thể duyệt lịch lúc này."));
                        }
                    } catch (error) {
                        console.error("Lỗi kết nối:", error);
                        alert("Lỗi kết nối mạng rồi Tâm ơi, kiểm tra lại nhé!");
                    }
                }


            </script>
            <script>
                async function tuChoiLich(id) {
                    // Hỏi ý kiến cho chắc chắn
                    if (!confirm("Tâm có chắc chắn muốn từ chối lịch học này không?")) return;

                    try {
                        const response = await fetch(`/tkb/tu-choi/${id}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ status: 'tu-choi' })
                        });

                        const data = await response.json();

                        if (response.ok && data.success) {
                            // Hiệu ứng làm mờ và xóa dòng tương tự như khi Duyệt
                            const row = document.getElementById(`row-${id}`);
                            row.style.transition = "all 0.5s ease";
                            row.style.backgroundColor = "#f8d7da"; // Màu đỏ nhạt báo hiệu từ chối
                            row.style.opacity = "0";

                            setTimeout(() => {
                                row.remove();
                                if (document.querySelectorAll('tbody tr').length === 0) {
                                    location.reload();
                                }
                            }, 500);
                        } else {
                            alert("Lỗi: " + (data.message || "Không thể từ chối lịch lúc này."));
                        }
                    } catch (error) {
                        console.error("Lỗi kết nối:", error);
                        alert("Có lỗi xảy ra khi kết nối đến máy chủ.");
                    }
                }
            </script>


            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    var chiTietModal = document.getElementById('chiTietDangKyModal');
                    if (!chiTietModal) return;

                    chiTietModal.addEventListener('show.bs.modal', function (event) {
                        var button = event.relatedTarget;
                        if (!button) return;

                        var monHoc = button.getAttribute('data-mon-hoc') || 'Chưa cập nhật';
                        var lopHoc = button.getAttribute('data-lop-hoc') || 'Chưa cập nhật';
                        var giangVien = button.getAttribute('data-giang-vien') || 'Chưa cập nhật';
                        var phongHoc = button.getAttribute('data-phong-hoc') || 'Chưa cập nhật';
                        var thoiGianHoc = button.getAttribute('data-thoi-gian-hoc') || 'Chưa cập nhật';
                        var ngayDangKy = button.getAttribute('data-ngay-dang-ky') || 'Chưa cập nhật';
                        var ngayDuyet = button.getAttribute('data-ngay-duyet') || 'Chưa cập nhật';
                        var trangThaiText = button.getAttribute('data-trang-thai-text') || 'Chưa cập nhật';
                        var trangThaiClass = button.getAttribute('data-trang-thai-class') || 'bg-secondary-subtle text-secondary';

                        document.getElementById('modalMonHoc').textContent = monHoc;
                        document.getElementById('modalLopGiangVien').textContent = lopHoc + ' - ' + giangVien;
                        document.getElementById('modalThoiGianHoc').textContent = thoiGianHoc;
                        document.getElementById('modalPhongHoc').textContent = phongHoc;
                        document.getElementById('modalNgayDangKy').textContent = ngayDangKy;
                        document.getElementById('modalNgayDuyet').textContent = ngayDuyet;

                        var badge = document.getElementById('modalTrangThai');
                        badge.className = 'badge px-3 py-2 rounded-pill ' + trangThaiClass;
                        badge.textContent = trangThaiText;
                    });
                });
            </script>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>