<% // Đảm bảo không bị lỗi khi dsTKB không được gửi từ controller const ds=Array.isArray(dsTKB) ? dsTKB : []; const
    d=new Date(); const mangThu=["Chủ Nhật", "Thứ 2" , "Thứ 3" , "Thứ 4" , "Thứ 5" , "Thứ 6" , "Thứ 7" ]; const
    thuHienTai=mangThu[d.getDay()]; const lichHomNay=ds.filter(l=> l.Thu === thuHienTai);
    %>

    <div class="card shadow-sm border-0 rounded-4 p-4 bg-white">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="text-primary fw-bold mb-0"><i class="fas fa-calendar-day me-2"></i>Lịch trình <%= thuHienTai %>
            </h5>
            <span class="badge bg-primary-subtle text-primary rounded-pill px-3">
                <%= lichHomNay.length %> môn học
            </span>
        </div>

        <div class="calendar-wrapper" style="min-width: 100%;">
            <div class="calendar-body-grid" style="grid-template-columns: 80px 1fr;">
                <% for(let t=1; t <=12; t++) { %>
                    <div class="time-slot" style="grid-row: <%= t %>;">Tiết <%= t %>
                    </div>
                    <% } %>

                        <% lichHomNay.forEach(item=> { %>
                            <div class="tkb-card color-<%= item.CaHoc === 'Sáng' ? 'sang' : (item.CaHoc === 'Chiều' ? 'chieu' : 'toi') %>"
                                style="grid-column: 2; grid-row: <%= item.TietBatDau %> / span <%= (item.TietKetThuc - item.TietBatDau + 1) %>;">
                                <div class="card-summary p-3">
                                    <strong class="fs-6 d-block">
                                        <%= item.MonHoc %>
                                    </strong>
                                    <div class="mt-2 small opacity-75">
                                        <i class="fas fa-map-marker-alt me-1"></i>
                                        <%= item.PhongHoc?.TenPhong %> |
                                            <i class="fas fa-user-tie me-1"></i>
                                            <%= item.GiangVien?.HoVaTen %>
                                    </div>
                                </div>
                            </div>
                            <% }) %>

            </div>
        </div>
    </div>