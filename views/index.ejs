<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            font-family: 'Quicksand', sans-serif;
            background-color: #f8f9fa;
        }

        /* Banner chính phía trên */
        .hero-banner {
            padding: 40px 0 20px 0;
            background: radial-gradient(circle at top right, #e3f2fd, #ffffff);
            margin-top: -10px;
        }

        .hero-banner h1 {
            font-size: 2.8rem;
            margin-bottom: 15px;
        }

        .hero-banner h1 span {
            color: #007bff !important;
        }

        /* Nút bấm chung */
        .main-btn {
            background: linear-gradient(135deg, #007bff 0%, #6610f2 100%);
            border: none;
            color: white;
            padding: 10px 30px;
            border-radius: 50px;
            font-weight: 600;
            transition: 0.3s;
        }

        .main-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(0, 123, 255, 0.3);
            color: white;
        }

        /* Tùy chỉnh Carousel (Banner trượt) */
        .banner-img {
            height: 450px;
            object-fit: cover;
            filter: brightness(0.7);
            /* Giảm độ sáng một chút để chữ nổi bật hơn */
        }

        .carousel-caption {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 20px;
            padding: 20px;
            bottom: 20%;
            backdrop-filter: blur(8px);
            /* Tăng độ mờ kính nhìn sẽ sang hơn */
        }

        /* Nút Chat nổi */
        .floating-chat {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #007bff 0%, #6610f2 100%);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            box-shadow: 0 5px 20px rgba(102, 16, 242, 0.4);
            cursor: pointer;
            transition: 0.3s;
            z-index: 1000;
        }

        .floating-chat:hover {
            transform: scale(1.1) rotate(10deg);
        }

        /* Tùy chỉnh kích thước ảnh banner để đồng nhất */
        .banner-img {
            height: 450px;
            object-fit: cover;
            /* Giúp ảnh không bị méo khi co giãn */
            filter: brightness(0.8);
            /* Làm ảnh tối lại một chút để chữ nổi lên */
        }

        /* Hiệu ứng chữ trong banner */
        .carousel-caption {
            background: rgba(0, 0, 0, 0.3);
            /* Tạo lớp nền mờ cho chữ dễ đọc */
            border-radius: 20px;
            padding: 20px;
            bottom: 20%;
            backdrop-filter: blur(5px);
            /* Hiệu ứng kính mờ hiện đại */
        }

        /* Tùy chỉnh các nút điều hướng tròn trịa hơn */
        .carousel-indicators [button] {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin: 0 5px;
        }
    </style>
</head>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<body>
    <!-- Phần đầu   -->
    <%- include('header') %>

        <!-- Nội dung   -->
        <% if (isLoggedIn && user && user.QuyenHan==='admin' ) { %>
            <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
            <% } %>

                <div class="container mt-5">
                    <% if(isLoggedIn && user){ %>

                        <div class="row">
                            <% if (user.QuyenHan==='admin' ) { %>
                                <div class="col-lg-10 mx-auto">
                                    <div class="card border-0 shadow-sm p-4" style="border-radius: 25px;">
                                        <h5 class="fw-bold mb-4 text-center"> <i
                                                class="fas fa-chart-pie text-danger me-2"></i>Thống kê hệ thống
                                        </h5>
                                        <div style="position: relative; margin: auto; height: 400px; width: 100%;">
                                            <canvas id="adminChart"></canvas>
                                        </div>
                                    </div>
                                </div>


                                <script>
                                    const ctx = document.getElementById('adminChart').getContext('2d');
                                    new Chart(ctx, {
                                        type: 'bar',
                                        data: {
                                            labels: ['Lớp đang học', 'Phòng còn trống', 'Giảng viên rảnh'],
                                            datasets: [{
                                                label: 'Số lượng',
                                                // Dùng tag EJS để nhận mảng từ Router gửi sang
                                                data: <%= JSON.stringify(thongKeDashboard) %>,
                                                backgroundColor: ['#ff758c', '#00cec9', '#6c5ce7'],
                                                borderRadius: 10
                                            }]
                                        },
                                        options: {
                                            responsive: true
                                        }
                                    });
                                </script>

                                <% } else { %>
                                    <div class="col-lg-5">
                                        <h5 class="fw-bold mb-3">
                                            <i class="fas fa-chalkboard-teacher text-danger me-2"></i>Lớp học và lịch
                                            học hôm nay
                                        </h5>
                                        <div class="list-group shadow-sm border-0">
                                            <% if (typeof dsLich !=='undefined' && dsLich.length> 0) { %>
                                                <% const tkb=dsLich[0]; %>
                                                    <a href="/tkb" class="text-decoration-none">
                                                        <div class="list-group-item p-4 border-0 mb-3 add-card"
                                                            style="border-radius: 20px; background: linear-gradient(135deg, #6610f2 0%, #007bff 100%); color: white; transition: 0.3s;">
                                                            <div
                                                                class="d-flex justify-content-between align-items-start">
                                                                <div>
                                                                    <h4 class="fw-bold mb-1">
                                                                        <%= tkb.PhongHoc ? tkb.PhongHoc.TenPhong
                                                                            : 'P.Trống' %> -
                                                                            <%= tkb.MonHoc ? tkb.MonHoc.TenMonHoc
                                                                                : 'Môn học' %>
                                                                    </h4>
                                                                    <p class="mb-2 opacity-75 small">
                                                                        Giảng viên: <%= tkb.GiangVien ?
                                                                            tkb.GiangVien.HoVaTen : 'Đang cập nhật' %>
                                                                    </p>
                                                                    <span
                                                                        class="badge bg-white text-primary rounded-pill px-3 py-2">
                                                                        <i class="fas fa-clock me-1"></i> Xem chi tiết
                                                                    </span>
                                                                </div>
                                                                <div class="text-end">
                                                                    <i class="fas fa-arrow-right fa-2x opacity-50"></i>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </a>
                                                    <% } else { %>
                                                        <p class="text-muted italic">Hiện chưa có lịch học nào cho Tâm
                                                            nhé! 🌿</p>
                                                        <% } %>
                                        </div>
                                    </div>
                                    <% } %>
                        </div>

                        <% } else { %>
                            <div class="row justify-content-center mt-2">
                                <div class="col-lg-11">
                                    <div id="welcomeCarousel" class="carousel slide shadow-lg" data-bs-ride="carousel"
                                        style="border-radius: 30px; overflow: hidden;">
                                        <div class="carousel-indicators">
                                            <button type="button" data-bs-target="#welcomeCarousel" data-bs-slide-to="0"
                                                class="active"></button>
                                            <button type="button" data-bs-target="#welcomeCarousel"
                                                data-bs-slide-to="1"></button>
                                            <button type="button" data-bs-target="#welcomeCarousel"
                                                data-bs-slide-to="2"></button>
                                        </div>
                                        <div class="carousel-inner">
                                            <div class="carousel-item active" data-bs-interval="5000">
                                                <img src="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&w=1200&q=80"
                                                    class="d-block w-100 banner-img" alt="Slide 1">
                                                <div class="carousel-caption">
                                                    <h2 class="fw-bold">Chào mừng bạn đến với Edu KT</h2>
                                                    <p>Nơi bắt đầu những ước mơ và kiến thức mới.</p>
                                                </div>
                                            </div>
                                            <div class="carousel-item" data-bs-interval="5000">
                                                <img src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?auto=format&fit=crop&w=1200&q=80"
                                                    class="d-block w-100 banner-img" alt="Slide 2">
                                                <div class="carousel-caption">
                                                    <h2 class="fw-bold">Học tập không giới hạn</h2>
                                                    <p>Khám phá kho tài liệu và lịch học trực tuyến dễ dàng.</p>
                                                </div>
                                            </div>
                                            <div class="carousel-item">
                                                <img src="https://images.unsplash.com/photo-1497215728101-856f4ea42174?auto=format&fit=crop&w=1200&q=80"
                                                    class="d-block w-100 banner-img" alt="Slide 3">
                                                <div class="carousel-caption">
                                                    <h2 class="fw-bold">Hỗ trợ tận tâm</h2>
                                                    <p>Chúng tôi luôn đồng hành cùng bạn trên mọi nẻo đường.</p>
                                                </div>
                                            </div>
                                        </div>
                                        <button class="carousel-control-prev" type="button"
                                            data-bs-target="#welcomeCarousel" data-bs-slide="prev">
                                            <span class="carousel-control-prev-icon"></span>
                                        </button>
                                        <button class="carousel-control-next" type="button"
                                            data-bs-target="#welcomeCarousel" data-bs-slide="next">
                                            <span class="carousel-control-next-icon"></span>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="floating-chat" title="Hỗ trợ trực tuyến">
                                <i class="fas fa-comment-dots"></i>
                            </div>
                            <% } %>
                </div>

                <style>
                    .hover-card {
                        transition: 0.3s;
                        border: 1px solid transparent;
                    }

                    .hover-card:hover {
                        transform: translateY(-5px);
                        border-color: #6610f2;
                        cursor: pointer;
                    }
                </style>
                <% if (!user && path==='/' ) { %>
                    <footer class="bg-white border-top py-5 mt-5">
                        <div class="container">
                            <div class="row gy-4">
                                <div class="col-md-4">
                                    <h5 class="fw-bold text-primary mb-3"><i class="fas fa-graduation-cap me-2"></i>Edu
                                        KT
                                        Center</h5>
                                    <p class="text-muted small">
                                        Hệ thống quản lý đào tạo hiện đại, hỗ trợ sinh viên và giảng viên tối ưu trong
                                        quá
                                        trình dạy và học.
                                    </p>
                                    <p class="fw-bold text-dark mb-0">Chịu trách nhiệm: <%= title || 'Nguyễn Ngọc Tâm'
                                            %>
                                    </p>
                                </div>

                                <div class="col-md-4">
                                    <h5 class="fw-bold text-dark mb-3">Thông tin liên hệ</h5>
                                    <ul class="list-unstyled text-muted small">
                                        <li class="mb-2"><i class="fas fa-map-marker-alt me-2 text-primary"></i> 18 Ung
                                            Văn
                                            Khiêm, Đông
                                            Xuyên, TP. Long Xuyên, An Giang</li>
                                        <li class="mb-2"><i class="fas fa-phone-alt me-2 text-primary"></i> Hotline:
                                            0123
                                            456 789</li>
                                        <li class="mb-2"><i class="fas fa-envelope me-2 text-primary"></i> email:
                                            hotro@edukt.vn</li>
                                    </ul>
                                </div>

                                <div class="col-md-4">
                                    <h5 class="fw-bold text-dark mb-3">Tiện ích</h5>
                                    <div class="d-flex gap-3">
                                        <a href="#" class="text-muted"><i class="fab fa-facebook fa-lg"></i></a>
                                        <a href="#" class="text-muted"><i class="fab fa-youtube fa-lg"></i></a>
                                        <a href="#" class="text-muted"><i class="fas fa-globe fa-lg"></i></a>
                                    </div>
                                    <p class="mt-3 text-muted small italic">Phát triển bởi <span
                                            class="fw-bold text-primary">Nguyễn Ngọc
                                            Tâm</span></p>
                                </div>
                            </div>

                            <hr class="my-4 text-muted opacity-25">

                            <div class="text-center">
                                <p class="text-muted small mb-0">&copy; 2026 Edu KT - Trung Tâm Tin Học </p>
                            </div>
                        </div>
                    </footer>
                    <% } %>
</body>

</html>