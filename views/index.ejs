<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            font-family: 'Quicksand', sans-serif;
            background-color: #f8f9fa;
        }

        .hero-banner {
            /* Chỗ này quan trọng nè Tâm: 
           Giảm từ 100px xuống còn 40px cho phía trên và 20px cho phía dưới */
            padding: 40px 0 20px 0;
            background: radial-gradient(circle at top right, #e3f2fd, #ffffff);

            /* Nếu muốn sát lên trên nữa, Tâm có thể thêm dòng này: */
            margin-top: -10px;
        }

        .main-btn {
            background: linear-gradient(135deg, #007bff 0%, #6610f2 100%);
            border: none;
            color: white;
            padding: 10px 30px;
            /* Anh thu nhỏ nút lại một xíu cho cân đối */
            border-radius: 50px;
            font-weight: 600;
            transition: 0.3s;
        }

        .main-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(0, 123, 255, 0.3);
            color: white;
        }

        .feature-box {
            border: none;
            border-radius: 20px;
            background: #ffffff;
            padding: 25px;
            /* Giảm nhẹ padding bên trong box */
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        .hero-banner h1 {
            font-size: 2.8rem;
            /* Giảm kích thước font một chút để không quá choán chỗ */
            margin-bottom: 15px;
        }

        .hero-banner h1 span {
            color: #007bff !important;
        }

        .hero-banner p {
            margin-bottom: 25px;
            /* Giảm khoảng cách dưới đoạn văn bản */
        }
    </style>
</head>

<body>
    <!-- Phần đầu   -->
    <%- include('header') %>

        <!-- Nội dung   -->
        <div class="container mt-5">
            <% if (isLoggedIn) { %>
                <div class="col-lg-5">
                    <h5 class="fw-bold mb-3">
                        <i class="fas fa-chalkboard-teacher text-danger me-2"></i>Lớp học của Tâm
                    </h5>
                    <div class="list-group shadow-sm border-0">
                        <% if (typeof dsTKB !=='undefined' && dsTKB.length> 0) { %>
                            <% const tkb=dsTKB[0]; %>
                                <a href="/tkb" class="text-decoration-none">
                                    <div class="list-group-item p-4 border-0 mb-3 add-card"
                                        style="border-radius: 20px; background: linear-gradient(135deg, #6610f2 0%, #007bff 100%); color: white; transition: 0.3s;">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h4 class="fw-bold mb-1">
                                                    <%= tkb.PhongHoc ? tkb.PhongHoc.TenPhong : 'P.Trống' %> -
                                                        <%= tkb.MonHoc ? tkb.MonHoc.TenMonHoc : 'Môn học' %>
                                                </h4>
                                                <p class="mb-2 opacity-75 small">
                                                    Giảng viên: <%= tkb.GiangVien ? tkb.GiangVien.HoVaTen
                                                        : 'Đang cập nhật' %>
                                                </p>
                                                <span class="badge bg-white text-primary rounded-pill px-3 py-2">
                                                    <i class="fas fa-clock me-1"></i> Xem chi tiết lịch học
                                                </span>
                                            </div>
                                            <div class="text-end">
                                                <i class="fas fa-arrow-right fa-2x opacity-50"></i>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                                <% } else { %>
                                    <p class="text-muted italic">Đăng nhập rồi nhưng chưa có lịch đâu Tâm ơi! 🌿</p>
                                    <% } %>
                    </div>
                </div>
                <% } else { %>
                    <div class="row g-4 mt-4">
                        <div class="col-md-4 text-center">
                            <div class="feature-box">
                                <i class="fas fa-bullhorn fa-3x text-warning mb-3"></i>
                                <h5>Tin Tức</h5>
                            </div>
                        </div>
                        <div class="col-md-4 text-center">
                            <div class="feature-box">
                                <i class="fas fa-school fa-3x text-info mb-3"></i>
                                <h5>Giới thiệu về Trung Tâm</h5>
                            </div>
                        </div>
                        <div class="col-md-4 text-center">
                            <div class="feature-box">
                                <i class="fas fa-headset fa-3x text-success mb-3"></i>
                                <h5>Box chat hỗ trợ</h5>
                            </div>
                        </div>
                    </div>
                    <% } %>
        </div>

        <%- include('footer') %>
</body>

</html>