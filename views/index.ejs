                                        aria-label="Zalo">
                                        <span style="font-weight: 700; font-size: 1rem;">Zalo</span>
                                    </a>
                                    <a href="mailto:contact@edukt.vn" aria-label="Email">
                                        <i class="fas fa-envelope"></i>
                                    </a>
                                    <a href="https://youtube.com" target="_blank" rel="noopener noreferrer"
                                        aria-label="YouTube">
                                        <i class="fab fa-youtube"></i>
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-8">
                            <h3 class="contact-subtitle text-center">Địa chỉ</h3>
                            <ul class="contact-list mb-4">
                                <li>
                                    <i class="fas fa-location-dot"></i>
                                    <a href="https://www.google.com/maps/search/?api=1&query=223+Ung+Van+Khiem%2C+Long+Xuyen%2C+An+Giang"
                                        target="_blank" rel="noopener noreferrer">
                                        Trụ sở chính: 223 Ung Văn Khiêm, P. Long Xuyên, An Giang
                                    </a>
                                </li>
                                <li>
                                    <i class="fas fa-location-dot"></i>
                                    <a href="https://www.google.com/maps/search/?api=1&query=Lo+KK7%2C+Nguyen+Duc+Canh%2C+Rach+Gia%2C+Kien+Giang"
                                        target="_blank" rel="noopener noreferrer">
                                        VPĐD (Rạch Giá): Lô KK7, Nguyễn Đức Cảnh, P. Rạch Giá, An Giang
                                    </a>
                                </li>
                            </ul>

                            <div class="contact-map">
                                <iframe
                                    src="https://www.google.com/maps?q=223%20Ung%20Van%20Khiem%2C%20Long%20Xuyen%2C%20An%20Giang&z=15&output=embed"
                                    allowfullscreen="" loading="lazy"
                                    referrerpolicy="no-referrer-when-downgrade"></iframe>
                            </div>
                        </div>
                    </div>
                    <div class="row gy-4 text-center text-md-start">
                        <div class="col-md-4">
                            <h5 class="fw-bold text-primary mb-3"><i class="fas fa-graduation-cap me-2"></i>Edu KT
                                Center</h5>
                            <p class="text-muted small">Hệ thống quản lý thời khóa biểu, tối ưu cho dạy và học.</p>
                            <p class="fw-bold text-dark mb-0">Chịu trách nhiệm: <%= title %>
                            </p>
                        </div>
                        <div class="col-md-4">
                            <h5 class="fw-bold text-dark mb-3">Thông tin liên hệ</h5>
                            <ul class="list-unstyled text-muted small">
                                <li class="mb-2"><i class="fas fa-map-marker-alt me-2 text-primary"></i> 18 Ung Văn
                                    Khiêm, An Giang</li>
                                <li class="mb-2"><i class="fas fa-phone-alt me-2 text-primary"></i> Hotline: 0123 456
                                    789</li>
                            </ul>
                        </div>
