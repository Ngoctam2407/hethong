<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <%- include('css') %>
</head>

<body>
    <%- include('header') %>

        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="mb-4">
                        <a href="/tkb" class="text-decoration-none text-primary fw-600">
                            <i class="fas fa-chevron-left me-2"></i>Quay lại Thời khóa biểu
                        </a>
                    </div>

                    <div class="add-card p-4 p-md-5 shadow-lg border-0 rounded-4 bg-white">
                        <div class="text-center mb-5">
                            <div class="icon-circle bg-info-subtle d-inline-block p-4 rounded-circle mb-3">
                                <i class="fas fa-calendar-plus fa-3x text-info"></i>
                            </div>
                            <h2 class="fw-bold">Đăng Ký Lịch Học</h2>
                            <p class="text-muted">Chọn thông tin chi tiết để hệ thống sắp xếp vào bảng tuần của em</p>
                        </div>

                        <form action="/tkb/dang-ky-luu" method="POST">
                            <div class="row">
                                <div class="col-md-12 mb-4">
                                    <label class="label-custom">Môn học học phần</label>
                                    <div class="input-group">
                                        <span class="input-group-text input-group-text-custom"><i
                                                class="fas fa-book"></i></span>
                                        <select name="MonHoc" class="form-select form-control-custom" required>
                                            <option value="" selected disabled>-- Chọn môn học --</option>
                                            <% dsmon.forEach(mon=> { %>
                                                <option value="<%= mon._id %>">
                                                    <%= mon.TenMonHoc %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </div>
                                </div>

                                <div class="col-md-6 mb-4">
                                    <label class="label-custom">Giảng viên đứng lớp</label>
                                    <div class="input-group">
                                        <span class="input-group-text input-group-text-custom"><i
                                                class="fas fa-user-tie"></i></span>
                                        <select name="GiangVien" class="form-select form-control-custom" required>
                                            <% dsgiangvien.forEach(gv=> { %>
                                                <option value="<%= gv._id %>">
                                                    <%= gv.HoVaTen %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </div>
                                </div>

                                <div class="col-md-6 mb-4">
                                    <label class="label-custom">Lớp học viên</label>
                                    <div class="input-group">
                                        <span class="input-group-text input-group-text-custom"><i
                                                class="fas fa-users"></i></span>
                                        <select name="LopHoc" class="form-select form-control-custom" required>
                                            <% dslop.forEach(lop=> { %>
                                                <option value="<%= lop._id %>">
                                                    <%= lop.TenLop %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </div>
                                </div>

                                <hr class="my-4 text-muted opacity-25">

                                <div class="col-md-4 mb-4">
                                    <label class="label-custom">Ngày trong tuần</label>
                                    <select name="Thu" class="form-select form-control-custom">
                                        <% ["Thứ 2", "Thứ 3" , "Thứ 4" , "Thứ 5" , "Thứ 6" , "Thứ 7" , "Chủ Nhật"
                                            ].forEach(thu=> { %>
                                            <option value="<%= thu %>">
                                                <%= thu %>
                                            </option>
                                            <% }) %>
                                    </select>
                                </div>

                                <div class="col-md-4 mb-4">
                                    <label class="label-custom">Tiết bắt đầu</label>
                                    <input type="number" name="TietBatDau" min="1" max="12"
                                        class="form-control form-control-custom" placeholder="Ví dụ: 1" required>
                                </div>

                                <div class="col-md-4 mb-4">
                                    <label class="label-custom">Tiết kết thúc</label>
                                    <input type="number" name="TietKetThuc" min="1" max="12"
                                        class="form-control form-control-custom" placeholder="Ví dụ: 9" required>
                                </div>
                                <div class="col-md-12 mb-4">
                                    <label class="label-custom">Ca học</label>
                                    <div class="input-group">
                                        <span class="input-group-text input-group-text-custom">
                                            <i class="fas fa-clock"></i>
                                        </span>
                                        <select name="CaHoc" class="form-select form-control-custom" required>
                                            <option value="" selected disabled>-- Chọn ca học --</option>
                                            <% dscaHoc.forEach(ca=> { %>
                                                <option value="<%= ca %>">
                                                    <%= ca %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </div>
                                </div>

                                <div class="col-md-12 mb-4">
                                    <label class="label-custom">Phòng học</label>
                                    <div class="input-group">
                                        <span class="input-group-text input-group-text-custom"><i
                                                class="fas fa-map-marker-alt"></i></span>
                                        <select name="PhongHoc" class="form-select form-control-custom" required>
                                            <% dsphong.forEach(p=> { %>
                                                <option value="<%= p._id %>">
                                                    <%= p.TenPhong %> - <%= p.LoaiPhong %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="d-grid gap-2 mt-3">
                                <button type="submit" class="btn main-btn shadow">
                                    <i class="fas fa-save me-2"></i> Xác nhận đăng ký lịch
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>