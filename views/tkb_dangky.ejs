<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <%- include('css') %>
</head>

<body>
    <%- include('header') %>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="mb-4">
                    <a href="/tkb" class="text-decoration-none text-primary fw-600">
                        <i class="fas fa-chevron-left me-2"></i>Quay lại Thời khóa biểu
                    </a>
                </div>

                <div class="add-card p-4 p-md-5 shadow-lg border-0 rounded-4 bg-white">
                    <div class="text-center mb-5">
                        <div class="icon-circle bg-info-subtle d-inline-block p-4 rounded-circle mb-3">
                            <i class="fas fa-calendar-plus fa-3x text-info"></i>
                        </div>
                        <h2 class="fw-bold">Đăng Ký Lịch Học</h2>
                        <p class="text-muted">Hệ thống sẽ chỉ cho đăng ký tuần hiện tại hoặc tuần mới, đồng thời kiểm tra môn hợp lệ theo lớp.</p>
                    </div>

                    <form action="/tkb/dang-ky-luu" method="POST">
                        <div class="row">
                            <div class="col-md-12 mb-4">
                                <label class="label-custom">Lớp học viên</label>
                                <div class="input-group">
                                    <span class="input-group-text input-group-text-custom"><i class="fas fa-users"></i></span>
                                    <select name="LopHoc" id="lopHocSelect" class="form-select form-control-custom" required>
                                        <option value="" selected disabled>-- Chọn lớp học --</option>
                                        <% dslop.forEach(function(lop) { %>
                                            <option value="<%= lop._id %>" data-si-so="<%= lop.SiSo || 0 %>" data-allowed-subjects="<%= (lop.DanhSachMonHoc || []).map(function(mon) { return mon._id.toString(); }).join(',') %>">
                                                <%= lop.TenLop %>
                                            </option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="form-text">Khi lớp đã được ràng buộc môn, chỉ các môn đó mới được chọn.</div>
                            </div>

                            <div class="col-md-12 mb-4">
                                <label class="label-custom">Môn học học phần</label>
                                <div class="input-group">
                                    <span class="input-group-text input-group-text-custom"><i class="fas fa-book"></i></span>
                                    <select name="MonHoc" id="monHocSelect" class="form-select form-control-custom" required>
                                        <option value="" selected disabled>-- Chọn môn học --</option>
                                        <% dsmon.forEach(function(mon) { %>
                                            <option value="<%= mon._id %>"><%= mon.TenMonHoc %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="form-text" id="monHocHint">Chọn lớp trước để hệ thống lọc môn phù hợp nếu lớp đã có ràng buộc.</div>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="label-custom">Giảng viên đứng lớp</label>
                                <div class="input-group">
                                    <span class="input-group-text input-group-text-custom"><i class="fas fa-user-tie"></i></span>
                                    <% if (user && user.QuyenHan === 'giangvien') { %>
                                        <input type="text" class="form-control form-control-custom" value="<%= user.HoVaTen %>" readonly>
                                        <input type="hidden" name="GiangVien" value="<%= user._id %>">
                                    <% } else { %>
                                        <select name="GiangVien" class="form-select form-control-custom" required>
                                            <% dsgiangvien.forEach(function(gv) { %>
                                                <option value="<%= gv._id %>"><%= gv.HoVaTen %></option>
                                            <% }) %>
                                        </select>
                                    <% } %>
                                </div>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="label-custom">Phòng học</label>
                                <div class="input-group">
                                    <span class="input-group-text input-group-text-custom"><i class="fas fa-map-marker-alt"></i></span>
                                    <select name="PhongHoc" id="phongHocSelect" class="form-select form-control-custom" required>
                                        <option value="" selected disabled>-- Chọn lớp, tuần, thứ và tiết để tìm phòng --</option>
                                        <% dsphong.forEach(function(p) { %>
                                            <option value="<%= p._id %>" data-original-label="<%= p.TenPhong %> - <%= p.LoaiPhong %> - Sức chứa: <%= p.SucChua || 0 %>"><%= p.TenPhong %> - <%= p.LoaiPhong %> - Sức chứa: <%= p.SucChua || 0 %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="form-text" id="phongHocHint">Hệ thống sẽ tự đánh dấu phòng trống/bận theo thời gian và sĩ số lớp.</div>
                            </div>

                            <div class="col-md-12 mb-4">
                                <div class="d-flex gap-4 align-items-start flex-wrap">
                                    <div style="flex: 0 0 60%; min-width: 280px;">
                                        <label class="label-custom">Tuần học đăng ký</label>
                                        <div class="input-group">
                                            <span class="input-group-text input-group-text-custom"><i class="fas fa-hashtag"></i></span>
                                            <select name="Tuan" id="tuanSelect" class="form-select form-control-custom" required>
                                                <% weeks.forEach(function(w) { %>
                                                    <option value="<%= w.number %>" <%= currentWeek == w.number ? 'selected' : '' %> <%= w.number < realCurrentWeek ? 'disabled' : '' %>>
                                                        <%= w.label %> <%= realCurrentWeek == w.number ? '(Tuần hiện tại)' : '' %>
                                                    </option>
                                                <% }); %>
                                            </select>
                                        </div>
                                        <div class="form-text">Các tuần cũ đã bị khóa để tránh đăng ký ngược thời gian.</div>
                                    </div>
                                    <div class="flex-grow-1">
                                        <label class="label-custom">Ca học suy ra</label>
                                        <input type="text" id="caHocPreview" class="form-control form-control-custom" value="Hệ thống sẽ tự suy ra" readonly style="border-radius: 12px !important;">
                                        <small class="text-muted ms-1" style="display: block; line-height: 1.2;">Tiết 1-5 là Sáng, 6-10 là Chiều, 11-12 là Tối.</small>
                                    </div>
                                </div>
                            </div>

                            <hr class="my-4 text-muted opacity-25">

                            <div class="col-md-4 mb-4">
                                <label class="label-custom">Ngày trong tuần</label>
                                <select name="Thu" id="thuSelect" class="form-select form-control-custom" required>
                                    <% ["Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7", "Chủ Nhật"].forEach(function(thu) { %>
                                        <option value="<%= thu %>"><%= thu %></option>
                                    <% }) %>
                                </select>
                            </div>

                            <div class="col-md-4 mb-4">
                                <label class="label-custom">Tiết bắt đầu</label>
                                <input type="number" name="TietBatDau" id="tietBatDauInput" min="1" max="12" class="form-control form-control-custom" placeholder="Ví dụ: 1" required>
                            </div>

                            <div class="col-md-4 mb-4">
                                <label class="label-custom">Tiết kết thúc</label>
                                <input type="number" name="TietKetThuc" id="tietKetThucInput" min="1" max="12" class="form-control form-control-custom" placeholder="Ví dụ: 9" required>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-3">
                            <button type="submit" class="btn main-btn shadow">
                                <i class="fas fa-save me-2"></i>Xác nhận đăng ký lịch
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function suyRaCaHoc() {
            const tietBatDau = parseInt(document.getElementById('tietBatDauInput').value, 10);
            const tietKetThuc = parseInt(document.getElementById('tietKetThucInput').value, 10);
            const caHocPreview = document.getElementById('caHocPreview');

            if (!tietBatDau || !tietKetThuc) {
                caHocPreview.value = 'Hệ thống sẽ tự suy ra';
                return;
            }

            if (tietBatDau <= 5 && tietKetThuc <= 5) {
                caHocPreview.value = 'Sáng';
                return;
            }

            if (tietBatDau >= 6 && tietKetThuc <= 10) {
                caHocPreview.value = 'Chiều';
                return;
            }

            if (tietBatDau >= 11) {
                caHocPreview.value = 'Tối';
                return;
            }

            caHocPreview.value = 'Ca học giao nhau, hệ thống sẽ tính theo tiết bắt đầu';
        }

        function capNhatMonHocTheoLop() {
            const lopHocSelect = document.getElementById('lopHocSelect');
            const monHocSelect = document.getElementById('monHocSelect');
            const monHocHint = document.getElementById('monHocHint');
            const selectedOption = lopHocSelect.options[lopHocSelect.selectedIndex];
            const allowedSubjects = selectedOption ? (selectedOption.getAttribute('data-allowed-subjects') || '').split(',').filter(Boolean) : [];
            let visibleCount = 0;

            Array.from(monHocSelect.options).forEach(function (option, index) {
                if (index === 0) {
                    option.hidden = false;
                    return;
                }

                const hopLe = !allowedSubjects.length || allowedSubjects.includes(option.value);
                option.hidden = !hopLe;
                if (!hopLe && option.selected) {
                    option.selected = false;
                }
                if (hopLe) {
                    visibleCount++;
                }
            });

            monHocHint.textContent = allowedSubjects.length
                ? 'Lớp này đang được ràng buộc ' + visibleCount + ' môn học có thể đăng ký.'
                : 'Lớp này chưa cấu hình ràng buộc môn, nên đang hiển thị toàn bộ môn.';
        }

        function resetPhongHocHint(message) {
            const phongHocSelect = document.getElementById('phongHocSelect');
            const phongHocHint = document.getElementById('phongHocHint');

            Array.from(phongHocSelect.options).forEach(function (option, index) {
                if (index === 0) {
                    option.textContent = '-- Chọn lớp, tuần, thứ và tiết để tìm phòng --';
                    option.disabled = true;
                    option.selected = true;
                    return;
                }

                option.disabled = false;
                option.textContent = option.getAttribute('data-original-label') || option.textContent;
                option.className = '';
                option.title = '';
            });

            phongHocHint.textContent = message || 'Hệ thống sẽ tự đánh dấu phòng trống/bận theo thời gian và sĩ số lớp.';
        }

        async function capNhatPhongHocThongMinh() {
            const lopHocSelect = document.getElementById('lopHocSelect');
            const tuanSelect = document.getElementById('tuanSelect');
            const thuSelect = document.getElementById('thuSelect');
            const tietBatDauInput = document.getElementById('tietBatDauInput');
            const tietKetThucInput = document.getElementById('tietKetThucInput');
            const phongHocSelect = document.getElementById('phongHocSelect');
            const phongHocHint = document.getElementById('phongHocHint');

            const lopHocID = lopHocSelect.value;
            const tuan = tuanSelect.value;
            const thu = thuSelect.value;
            const tietBD = parseInt(tietBatDauInput.value, 10);
            const tietKT = parseInt(tietKetThucInput.value, 10);

            if (!lopHocID || !tuan || !thu || !tietBD || !tietKT) {
                resetPhongHocHint('Chọn đủ lớp, tuần, thứ, tiết bắt đầu và tiết kết thúc để hệ thống tìm phòng trống.');
                return;
            }

            if (tietKT < tietBD) {
                resetPhongHocHint('Tiết kết thúc phải lớn hơn hoặc bằng tiết bắt đầu.');
                return;
            }

            phongHocHint.textContent = 'Đang kiểm tra phòng trống theo thời gian và sĩ số lớp...';

            try {
                const params = new URLSearchParams({ tuan, thu, tietBD, tietKT, lopHocID });
                const response = await fetch('/tkb/api/room-status?' + params.toString());
                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.message || 'Không kiểm tra được phòng.');
                }

                const roomMap = new Map((data.rooms || []).map(function (room) {
                    return [String(room._id), room];
                }));
                let firstAvailable = '';

                Array.from(phongHocSelect.options).forEach(function (option, index) {
                    if (index === 0) {
                        option.textContent = '-- Chọn phòng phù hợp --';
                        option.disabled = true;
                        return;
                    }

                    const room = roomMap.get(option.value);
                    const baseLabel = option.getAttribute('data-original-label') || option.textContent;
                    if (!room) {
                        option.disabled = true;
                        option.textContent = baseLabel + ' - Không có dữ liệu';
                        option.title = 'Không có dữ liệu kiểm tra phòng';
                        return;
                    }

                    option.disabled = !room.available;
                    option.textContent = baseLabel + (room.available ? ' - Trống' : ' - Không trống: ' + room.reason);
                    option.title = room.reason;
                    option.className = room.available ? 'text-success' : 'text-muted';

                    if (room.available && !firstAvailable) {
                        firstAvailable = option.value;
                    }
                });

                if (!firstAvailable) {
                    phongHocSelect.value = '';
                    phongHocHint.textContent = data.isPast
                        ? 'Ngày học ' + data.ngayHocHienThi + ' đã qua, không thể đăng ký.'
                        : 'Không có phòng trống đủ sức chứa cho khung ' + thu + ', tiết ' + tietBD + '-' + tietKT + ', tuần ' + tuan + '.';
                } else {
                    const selectedOption = phongHocSelect.options[phongHocSelect.selectedIndex];
                    if (!phongHocSelect.value || (selectedOption && selectedOption.disabled)) {
                        phongHocSelect.value = firstAvailable;
                    }
                    phongHocHint.textContent = 'Tìm thấy ' + data.availableRooms.length + ' phòng trống cho ngày ' + data.ngayHocHienThi + ', sĩ số lớp: ' + data.siSo + '.';
                }
            } catch (err) {
                resetPhongHocHint('Không kiểm tra được trạng thái phòng: ' + err.message);
            }
        }

        function capNhatThuTheoTuan() {
            const tuanSelect = document.getElementById('tuanSelect');
            const thuSelect = document.getElementById('thuSelect');
            const realCurrentWeek = <%= realCurrentWeek || 1 %>;
            const selectedWeek = parseInt(tuanSelect.value, 10);
            const today = new Date();
            const jsDay = today.getDay();
            const todayOffset = jsDay === 0 ? 6 : jsDay - 1;

            Array.from(thuSelect.options).forEach(function (option, index) {
                const daQua = selectedWeek === realCurrentWeek && index < todayOffset;
                option.disabled = daQua;
                option.textContent = option.value + (daQua ? ' - đã qua' : '');
            });

            if (thuSelect.options[thuSelect.selectedIndex] && thuSelect.options[thuSelect.selectedIndex].disabled) {
                const optionHopLe = Array.from(thuSelect.options).find(function (option) {
                    return !option.disabled;
                });
                if (optionHopLe) thuSelect.value = optionHopLe.value;
            }
        }

        document.getElementById('tietBatDauInput').addEventListener('input', suyRaCaHoc);
        document.getElementById('tietKetThucInput').addEventListener('input', suyRaCaHoc);
        document.getElementById('lopHocSelect').addEventListener('change', function () {
            capNhatMonHocTheoLop();
            capNhatPhongHocThongMinh();
        });
        document.getElementById('tuanSelect').addEventListener('change', function () {
            capNhatThuTheoTuan();
            capNhatPhongHocThongMinh();
        });
        document.getElementById('thuSelect').addEventListener('change', capNhatPhongHocThongMinh);
        document.getElementById('tietBatDauInput').addEventListener('input', capNhatPhongHocThongMinh);
        document.getElementById('tietKetThucInput').addEventListener('input', capNhatPhongHocThongMinh);
        capNhatMonHocTheoLop();
        capNhatThuTheoTuan();
        resetPhongHocHint();
    </script>
</body>

</html>
