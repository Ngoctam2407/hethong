<style>
    .brand-kt {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
    }

    .brand-kt img {
        width: 56px;
        height: 56px;
        object-fit: contain;
    }

    .brand-kt-text {
        display: flex;
        flex-direction: column;
        line-height: 1.05;
    }

    .brand-kt-title {
        margin: 0;
        font-size: 1.35rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        color: #1b6fd8;
    }

    .brand-kt-title .accent {
        color: #ff7a1a;
    }

    .brand-kt-subtitle {
        margin: 0;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #0f4c5c;
    }

    .push-actions {
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .push-actions .btn {
        border-radius: 10px;
    }

    @media (max-width: 576px) {
        .brand-kt {
            gap: 10px;
        }

        .brand-kt img {
            width: 46px;
            height: 46px;
        }

        .brand-kt-title {
            font-size: 1.1rem;
        }

        .brand-kt-subtitle {
            font-size: 0.64rem;
            letter-spacing: 0.12em;
        }
    }
</style>

