<% if (typeof path !=='undefined' && (path==='/' || path==='/taikhoan' )) { %>
    <section class="hero-banner py-5">
        <div class="container text-center">
            <% if (!user) { %>
                <h1 class="display-3 fw-bold mb-4" style="color: #2d3436;">
                    Hệ Thống<br><span style="color: #1b6fd8;">KT</span>
                </h1>
                <p class="text-muted fs-5 mb-5">
                    Chào mừng bạn đến với Trung Tâm KT. <br>
                    Vui lòng <strong>Đăng nhập</strong> để xem chi tiết thông tin của cá nhân.
                </p>
                <% } else if (user.QuyenHan==='admin' ) { %>
                    <h1 class="display-4 fw-bold mb-4" style="color: #2d3436;">
                        Chào Admin, <span style="color: #6c5ce7;">
                            <%= user.HoVaTen %>
                        </span>
                    </h1>
                    <p class="text-muted fs-5 mb-4">Cố gắng cập nhật thông tin thường xuyên nhé!</p>
                    <% } else if (user.QuyenHan==='giangvien' ) { %>
                        <h1 class="display-4 fw-bold mb-4" style="color: #2d3436;">
                            Chào Thầy/Cô, <span style="color: #fab1a0;">
                                <%= user.HoVaTen %>
                            </span>
                        </h1>
                        <p class="text-muted fs-5 mb-4">Chúc Thầy/Cô một ngày lên lớp tràn đầy năng lượng!</p>
                        <% } else if (user.QuyenHan==='sinhvien' ) { %>
                            <h1 class="display-4 fw-bold mb-4" style="color: #2d3436;">
                                Chào Bạn, <span style="color: #00cec9;">
                                    <%= user.HoVaTen %>
                                </span>
                            </h1>
                            <p class="text-muted fs-5 mb-4">Đã đến lúc bắt đầu bài học mới rồi. Cố lên nhé!</p>
                            <% } %>
        </div>
    </section>
    <% } %>

        <% if (message) { %>
            <% const laLoi=String(message).includes('text-danger'); %>
                <div id="toastThongBao" class="position-fixed end-0 bottom-0 p-3"
                    style="z-index: 1090; pointer-events: none;">
                    <div class="toast show border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true"
                        style="min-width: 320px; max-width: 420px; border-radius: 12px; overflow: hidden; pointer-events: auto;">
                        <div
                            class="toast-header <%= laLoi ? 'bg-danger-subtle text-danger' : 'bg-success-subtle text-success' %>">
                            <i class="fas <%= laLoi ? 'fa-circle-exclamation' : 'fa-circle-check' %> me-2"></i>
                            <strong class="me-auto">Thông báo</strong>
                            <button type="button" class="btn-close" aria-label="Close"
                                onclick="dongToastThongBao()"></button>
                        </div>
                        <div class="toast-body bg-white">
                            <%- message %>
                        </div>
                    </div>
                </div>

                <script>
                    function dongToastThongBao() {
                        const toast = document.getElementById('toastThongBao');
                        if (toast) {
                            toast.style.transition = 'opacity 0.25s ease';
                            toast.style.opacity = '0';
                            setTimeout(() => toast.remove(), 250);
                        }
                    }
                    setTimeout(dongToastThongBao, 4000);
                </script>
                <% } %>

                            <script>
                                document.addEventListener('DOMContentLoaded', function () {
                                    var notifItems = document.getElementById('notif-items');

                                    if (!notifItems) return;

                                    function capNhatThongBao() {
                                        fetch('/thongbao/danh-sach')
                                            .then(function (res) { return res.json(); })
                                            .then(function (data) {
                                                var notifItems = document.getElementById('notif-items');
                                                if (!notifItems) return;

                                                if (data && data.length > 0) {
                                                    var html = '';
                                                    data.forEach(function (item) {
                                                        html += `
                        <li>
                            <a class="dropdown-item py-2 px-4 ${item.DaXem ? '' : 'bg-light'}"
                               href="${item.LienKet}" onclick="daXemThongBao('${item._id}')">
                                <div class="fw-bold ${item.DaXem ? 'text-secondary' : 'text-info'}" style="font-size: 0.85rem;">
                                    <i class="fas fa-envelope-open-text me-1"></i> ${item.TieuDe}
                                </div>
                                <div class="small text-muted text-wrap" style="line-height: 1.3;">${item.NoiDung}</div>
                            </a>
                        </li>
                    `;
                                                    });
                                                    notifItems.innerHTML = html;
                                                } else {
                                                    notifItems.innerHTML = '<li class="px-4 py-3 text-center text-muted small">Bạn chưa có thông báo nào mới</li>';
                                                }
                                            })
                                            .catch(function (err) {
                                                console.error('Lỗi tải thông báo:', err);
                                                var notifItems = document.getElementById('notif-items');
                                                if (notifItems) {
                                                    notifItems.innerHTML = '<li class="px-4 py-3 text-center text-danger small">Không thể tải thông báo</li>';
                                                }
                                            });
                                    }

                                    window.daXemThongBao = function (id) {
                                        fetch('/thongbao/da-xem/' + id, { method: 'POST' });
                                    };

                                    capNhatThongBao();
                                });
                            </script>

                            <script>
                                document.addEventListener('DOMContentLoaded', function () {
                                    var adminBtn = document.getElementById('adminDropdownBtn');
                                    var adminMenu = document.getElementById('adminDropdownMenu');
                                    if (!adminBtn || !adminMenu) return;

                                    var daGanFallback = false;

                                    function dongMenu() {
                                        adminMenu.classList.remove('show');
                                        adminBtn.classList.remove('show');
                                        adminBtn.setAttribute('aria-expanded', 'false');
                                    }

                                    function moMenu() {
                                        adminMenu.classList.add('show');
                                        adminBtn.classList.add('show');
                                        adminBtn.setAttribute('aria-expanded', 'true');
                                    }

                                    function toggleMenu() {
                                        if (adminMenu.classList.contains('show')) {
                                            dongMenu();
                                            return;
                                        }
                                        moMenu();
                                    }

                                    function ganFallbackNeuCan() {
                                        if (daGanFallback) return;
                                        daGanFallback = true;

                                        adminBtn.addEventListener('click', function (e) {
                                            e.preventDefault();
                                            e.stopPropagation();
                                            toggleMenu();
                                        });

                                        document.addEventListener('click', function (e) {
                                            if (!adminMenu.classList.contains('show')) return;
                                            if (adminBtn.contains(e.target) || adminMenu.contains(e.target)) return;
                                            dongMenu();
                                        });
                                    }

                                    try {
                                        if (window.bootstrap && bootstrap.Dropdown) {
                                            if (!bootstrap.Dropdown.getInstance(adminBtn)) {
                                                new bootstrap.Dropdown(adminBtn);
                                            }
                                        } else {
                                            ganFallbackNeuCan();
                                        }
                                    } catch (err) {
                                        ganFallbackNeuCan();
                                    }
                                });
                            </script>


