<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <%- include('css') %>
</head>

<body>
    <%- include('header') %>

        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="mb-4">
                        <a href="/taikhoan" class="text-decoration-none text-primary fw-600">
                            <i class="fas fa-arrow-left me-2"></i>Trở về danh sách
                        </a>
                    </div>

                    <div class="add-card p-4 p-md-5 shadow-sm bg-white" style="border-radius: 20px;">
                        <div class="text-center mb-5">
                            <div class="icon-circle bg-info-subtle d-inline-block p-4 rounded-circle mb-3">
                                <i class="fas fa-user-edit fa-3x text-info"></i>
                            </div>
                            <h2 class="fw-bold">Cập Nhật Tài Khoản</h2>
                            <p class="text-muted">Đang chỉnh sửa cho: <strong>
                                    <%= tk.HoVaTen %>
                                </strong></p>
                        </div>

                        <form action="/taikhoan/sua/<%= tk._id %>" method="POST">
                            <div class="row">
                                <div class="col-md-12 mb-4">
                                    <label class="label-custom fw-bold">Họ và tên</label>
                                    <input type="text" name="HoVaTen" class="form-control" value="<%= tk.HoVaTen %>"
                                        required>
                                </div>

                                <div class="col-md-6 mb-4">
                                    <label class="label-custom fw-bold">Email</label>
                                    <input type="email" name="Email" class="form-control" value="<%= tk.Email %>"
                                        required>
                                </div>

                                <div class="col-md-6 mb-4">
                                    <label class="label-custom fw-bold">Tên đăng nhập</label>
                                    <input type="text" name="TenDangNhap" class="form-control"
                                        value="<%= tk.TenDangNhap %>" required>
                                </div>

                                <div class="col-md-12 mb-4">
                                    <label class="label-custom fw-bold">Mật khẩu (Để trống nếu không muốn đổi)</label>
                                    <div class="input-group">
                                        <input type="password" name="MatKhau" id="inputMatKhau" class="form-control"
                                            placeholder="••••••••">
                                        <button class="btn btn-outline-secondary" type="button" id="btnShowPass">
                                            <i class="fas fa-eye" id="eyeIcon"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="col-md-12 mb-4">
                                    <label class="label-custom fw-bold">Quyền hạn</label>
                                    <select name="QuyenHan" id="roleSelect" class="form-select border-info"
                                        onchange="toggleExtraFields()">
                                        <option value="sinhvien" <%=tk.QuyenHan==='sinhvien' ? 'selected' : '' %>>Sinh
                                            viên</option>
                                        <option value="giangvien" <%=tk.QuyenHan==='giangvien' ? 'selected' : '' %>
                                            >Giảng viên</option>
                                        <option value="admin" <%=tk.QuyenHan==='admin' ? 'selected' : '' %>>Quản trị
                                            viên</option>
                                    </select>
                                </div>

                                <hr class="my-4">

                                <div id="sinhvienFields" class="row extra-fields">
                                    <h5 class="text-primary mb-3"><i class="fas fa-graduation-cap me-2"></i>Thông tin
                                        học tập</h5>
                                    <div class="col-md-6 mb-4">
                                        <label class="label-custom fw-bold">MSSV</label>
                                        <input type="text" name="MSSV" class="form-control"
                                            value="<%= detail && detail.MSSV ? detail.MSSV : '' %>">
                                    </div>
                                    <div class="col-md-6 mb-4">
                                        <label class="label-custom fw-bold">Lớp học</label>
                                        <select name="IDLop" class="form-select">
                                            <option value="">-- Chọn lớp --</option>
                                            <% dsLop.forEach(lop=> { %>
                                                <option value="<%= lop._id %>" <%=(detail && detail.IDLop &&
                                                    detail.IDLop.toString()===lop._id.toString()) ? 'selected' : '' %>>
                                                    <%= lop.TenLop %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </div>
                                </div>

                                <div id="giangvienFields" class="row extra-fields" style="display: none;">
                                    <h5 class="text-success mb-3"><i class="fas fa-chalkboard-teacher me-2"></i>Thông
                                        tin chuyên môn</h5>
                                    <div class="col-md-6 mb-4">
                                        <label class="label-custom fw-bold">Mã giảng viên</label>
                                        <input type="text" name="MaGV" class="form-control"
                                            value="<%= detail && detail.MaGV ? detail.MaGV : '' %>">
                                    </div>
                                    <div class="col-md-6 mb-4">
                                        <label class="label-custom fw-bold">Lĩnh vực dạy</label>
                                        <input type="text" name="LinhVuc" class="form-control"
                                            value="<%= detail && detail.LinhVuc ? detail.LinhVuc : '' %>">
                                    </div>
                                    <div class="col-md-12 mb-4">
                                        <label class="label-custom fw-bold">Số điện thoại</label>
                                        <input type="text" name="SoDienThoai" class="form-control"
                                            value="<%= detail && detail.SoDienThoai ? detail.SoDienThoai : '' %>">
                                    </div>
                                </div>
                            </div>

                            <div class="d-grid gap-2 mt-4">
                                <button type="submit" class="btn btn-info btn-lg text-white shadow rounded-pill">
                                    <i class="fas fa-save me-2"></i>Cập nhật thông tin
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <%- include('footer') %>

            <script>
                // Hàm ẩn hiện các trường nhập liệu
                function toggleExtraFields() {
                    const role = document.getElementById('roleSelect').value;
                    const svFields = document.getElementById('sinhvienFields');
                    const gvFields = document.getElementById('giangvienFields');

                    svFields.style.display = 'none';
                    gvFields.style.display = 'none';

                    if (role === 'sinhvien') svFields.style.display = 'flex';
                    else if (role === 'giangvien') gvFields.style.display = 'flex';
                }

                // JS cho nút hiện mật khẩu
                const btnShowPass = document.getElementById('btnShowPass');
                const inputMatKhau = document.getElementById('inputMatKhau');
                const eyeIcon = document.getElementById('eyeIcon');

                btnShowPass.addEventListener('click', function () {
                    if (inputMatKhau.type === 'password') {
                        inputMatKhau.type = 'text';
                        eyeIcon.classList.replace('fa-eye', 'fa-eye-slash');
                    } else {
                        inputMatKhau.type = 'password';
                        eyeIcon.classList.replace('fa-eye-slash', 'fa-eye');
                    }
                });

                // Chạy ngay khi load trang
                window.onload = toggleExtraFields;
            </script>
</body>

</html>