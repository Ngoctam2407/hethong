<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <%- include('css') %>
</head>

<body>
    <%- include('header') %>

        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-lg-7">

                    <div class="mb-4">
                        <a href="/taikhoan" class="text-decoration-none text-primary fw-600">
                            <i class="fas fa-arrow-left me-2"></i>Trở về danh sách
                        </a>
                    </div>

                    <div class="add-card p-4 p-md-5">
                        <div class="text-center mb-5">
                            <div class="icon-circle bg-info-subtle d-inline-block p-4 rounded-circle mb-3">
                                <i class="fas fa-user-edit fa-3x text-info"></i>
                            </div>
                            <h2 class="fw-bold">Cập Nhật Tài Khoản</h2>
                            <p class="text-muted">Thay đổi thông tin cho thành viên <strong>
                                    <%= tk.HoVaTen %>
                                </strong></p>
                        </div>

                        <form action="/taikhoan/sua/<%= tk._id %>" method="POST">
                            <div class="row">
                                <div class="col-md-12 mb-4">
                                    <label class="label-custom">Họ và tên</label>
                                    <div class="input-group">
                                        <span class="input-group-text input-group-text-custom"><i
                                                class="fas fa-id-card"></i></span>
                                        <input type="text" name="HoVaTen" class="form-control form-control-custom"
                                            value="<%= tk.HoVaTen %>" required>
                                    </div>
                                </div>

                                <div class="col-md-12 mb-4">
                                    <label class="label-custom">Địa chỉ Email</label>
                                    <div class="input-group">
                                        <span class="input-group-text input-group-text-custom"><i
                                                class="fas fa-envelope"></i></span>
                                        <input type="email" name="Email" class="form-control form-control-custom"
                                            value="<%= tk.Email %>" required>
                                    </div>
                                </div>

                                <div class="col-md-12 mb-4">
                                    <label class="label-custom">Tên đăng nhập (Có thể thay đổi)</label>
                                    <div class="input-group">
                                        <span class="input-group-text input-group-text-custom">
                                            <i class="fas fa-at"></i> </span>
                                        <input type="text" name="TenDangNhap" class="form-control form-control-custom"
                                            value="<%= tk.TenDangNhap %>" required>
                                    </div>
                                </div>

                                <div class="col-md-12 mb-4">
                                    <label class="label-custom">Mật khẩu (Có thể đổi mật khẩu)</label>
                                    <div class="input-group">
                                        <span class="input-group-text input-group-text-custom">
                                            <i class="fas fa-key"></i>
                                        </span>

                                        <input type="password" name="MatKhau" id="inputMatKhau"
                                            class="form-control form-control-custom" value="********"
                                            placeholder="Nhập mật khẩu mới nếu muốn đổi...">

                                        <button class="btn btn-outline-secondary border-start-0" type="button"
                                            id="btnShowPass"
                                            style="border-top-right-radius: 10px; border-bottom-right-radius: 10px; border: 1px solid #ced4da;">
                                            <i class="fas fa-eye" id="eyeIcon"></i>
                                        </button>
                                    </div>
                                    <small class="text-muted mt-1 d-block"><i class="fas fa-info-circle me-1"></i> Mật
                                        khẩu đã được mã hóa bảo mật cấp
                                        cao sau khi đã lưu.</small>
                                </div>
                            </div>
                            <script>
                                // 1. Lấy các phần tử cần thiết thông qua ID mà Tâm đã đặt
                                const btnShowPass = document.getElementById('btnShowPass');
                                const inputMatKhau = document.getElementById('inputMatKhau');
                                const eyeIcon = document.getElementById('eyeIcon');

                                // 2. Lắng nghe sự kiện click vào nút con mắt
                                btnShowPass.addEventListener('click', function () {
                                    // Kiểm tra: Nếu đang là 'password' (ẩn) thì chuyển thành 'text' (hiện) và ngược lại
                                    if (inputMatKhau.type === 'password') {
                                        inputMatKhau.type = 'text';

                                        // Đổi icon sang con mắt có gạch chéo (fa-eye-slash) cho đúng logic nè
                                        eyeIcon.classList.remove('fa-eye');
                                        eyeIcon.classList.add('fa-eye-slash');
                                    } else {
                                        inputMatKhau.type = 'password';

                                        // Đổi icon về con mắt bình thường
                                        eyeIcon.classList.remove('fa-eye-slash');
                                        eyeIcon.classList.add('fa-eye');
                                    }
                                });
                            </script>

                            <div class="col-md-12 mb-4">
                                <label class="label-custom">Phân quyền hệ thống</label>
                                <select name="QuyenHan" class="form-select form-control-custom">

                                    <option value="sinhvien" <%=tk.QuyenHan==='sinhvien' ? 'selected' : '' %>>
                                        Người dùng / Sinh viên
                                    </option>

                                    <option value="giangvien" <%=tk.QuyenHan==='giangvien' ? 'selected' : '' %>>
                                        Người dùng / Giảng viên
                                    </option>

                                    <option value="admin" <%=tk.QuyenHan==='admin' ? 'selected' : '' %>>
                                        Quản trị viên (Admin)
                                    </option>

                                </select>
                            </div>
                    </div>

                    <div class="d-grid gap-2 mt-3">
                        <button type="submit" class="btn main-btn shadow"
                            style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%);">
                            <i class="fas fa-save me-2"></i> Lưu thay đổi
                        </button>
                    </div>
                    </form>
                </div>
            </div>
        </div>
        </div>

        <%- include('footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>