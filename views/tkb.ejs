<div class="view-switcher-container mb-3">
    <div class="view-nav shadow-sm">
        <button class="nav-item active" onclick="switchView('grid')">
            <i class="fas fa-th-large"></i> <span>Chế độ Lưới</span>
        </button>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white p-3">
    <div class="calendar-wrapper">
        <div class="calendar-header-grid">
            <div class="time-col">Tiết</div>
            <% const days=["Thứ 2", "Thứ 3" , "Thứ 4" , "Thứ 5" , "Thứ 6" , "Thứ 7" , "Chủ Nhật" ]; %>
                <% days.forEach(day=> { %>
                    <div class="day-col fw-bold text-uppercase">
                        <%= day %>
                    </div>
                    <% }) %>
        </div>

        <div class="calendar-body-grid">
            <% for(let t=1; t <=12; t++) { %>
                <div class="time-slot" style="grid-row: <%= t %>;">T.<%= t %>
                </div>
                <% } %>

                    <% const dayToCol={ "Thứ 2" : 2, "Thứ 3" : 3, "Thứ 4" : 4, "Thứ 5" : 5, "Thứ 6" : 6, "Thứ 7" :
                        7, "Chủ Nhật" : 8 }; %>
                        <% dsTKB.forEach(item=> { %>
                            <div class="tkb-card color-<%= item.CaHoc === 'Sáng' ? 'sang' : (item.CaHoc === 'Chiều' ? 'chieu' : 'toi') %>"
                                style="grid-column: <%= dayToCol[item.Thu] %>; 
                            grid-row: <%= item.TietBatDau || 1 %> / span <%= (item.TietKetThuc - item.TietBatDau + 1) || 3 %>;">

                                <div class="card-summary">
                                    <strong class="text-truncate d-block">
                                        <%= item.MonHoc %>
                                    </strong>
                                    <small><i class="fas fa-map-marker-alt"></i>
                                        <%= item.PhongHoc?.TenPhong %>
                                    </small>
                                </div>

                                <div class="card-detail-hover">
                                    <div class="detail-content">
                                        <p><i class="fas fa-user-tie me-1"></i>
                                            <%= item.GiangVien?.HoVaTen %>
                                        </p>
                                        <p><i class="fas fa-clock me-1"></i> Tiết: <%= item.TietBatDau %>-<%=
                                                    item.TietKetThuc %>
                                        </p>
                                        <p><i class="fas fa-graduation-cap me-1"></i> Lớp: <%= item.LopHoc || 'Chưa rõ'
                                                %>
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
        </div>
    </div>
</div>

<style>
    /* 1. Thanh điều hướng chế độ xem */
    .view-switcher-container {
        display: flex;
        justify-content: flex-start;
    }

    .view-nav {
        display: inline-flex;
        background-color: #f1f3f4;
        padding: 5px;
        border-radius: 12px;
        border: 1px solid #e0e0e0;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 10px;
        text-decoration: none;
        color: #5f6368;
        font-weight: 500;
        font-size: 0.9rem;
        border: none;
        background: transparent;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .nav-item.active {
        background: linear-gradient(135deg, #1e70ff 0%, #8337ff 100%);
        color: white !important;
        box-shadow: 0 4px 10px rgba(30, 112, 255, 0.2);
    }

    /* 2. Khung TKB tổng thể */
    .calendar-wrapper {
        display: flex;
        flex-direction: column;
        min-width: 900px;
        background-color: #fff;
        border: 1px solid #dee2e6;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }

    .calendar-header-grid {
        display: grid;
        grid-template-columns: 80px repeat(7, 1fr);
        background: #f8f9fa;
        border-bottom: 1px solid #dee2e6;
        text-align: center;
    }

    .day-col {
        padding: 12px 0;
        border-right: 1px solid #eee;
        color: #4e73df;
    }

    .calendar-body-grid {
        display: grid;
        grid-template-columns: 80px repeat(7, 1fr);
        grid-template-rows: repeat(12, 60px);
        position: relative;
        background-color: #fff;
        grid-auto-rows: 0;
        overflow: hidden;
    }

    /* 3. Ô tiết học và đường kẻ */
    .time-slot {
        border-right: 1px solid #eee;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fdfdfd;
        font-size: 0.85rem;
        color: #888;
    }

    /* 4. Thẻ môn học và hiệu ứng Hover mượt mà */
    .tkb-card {
        margin: 4px;
        border-radius: 12px;
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-sizing: border-box;
        border: 1px solid rgba(0, 0, 0, 0.05);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
    }

    .card-summary {
        padding: 8px;
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .card-detail-hover {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(5px);
        color: white !important;
        padding: 10px;
        font-size: 0.75rem;
        transform: translateY(101%);
        transition: transform 0.3s ease;
    }

    .tkb-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        z-index: 10;
    }

    .tkb-card:hover .card-detail-hover {
        transform: translateY(0);
    }

    /* 5. Màu sắc ca học rực rỡ */
    .color-sang {
        background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
        color: #0d47a1;
        border-left: 4px solid #0d47a1;
    }

    .color-chieu {
        background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
        color: #e65100;
        border-left: 4px solid #e65100;
    }

    .color-toi {
        background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
        color: #1b5e20;
        border-left: 4px solid #1b5e20;
    }
</style>