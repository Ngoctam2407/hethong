<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            font-family: 'Quicksand', sans-serif;
            background-color: #f4f7fe;
        }

        .main-btn {
            background: linear-gradient(135deg, #6e8efb, #a777e3);
            border: none;
            color: white;
            padding: 10px 25px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s;
            display: inline-block;
        }

        .main-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(110, 142, 251, 0.4);
            color: white;
        }

        /* --- STYLE MA TRẬN (ADMIN & GIẢNG VIÊN) --- */
        .table-admin-wrapper {
            background: white;
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            overflow: hidden;
        }

        .admin-tkb-table {
            width: 100%;
            table-layout: fixed;
            border-collapse: separate;
            border-spacing: 0;
        }

        .admin-tkb-table th,
        .admin-tkb-table td {
            border: 1px solid #e2e8f0 !important;
            padding: 12px 8px !important;

        }

        .admin-time-col {
            width: 96px;
            min-width: 96px;
        }

        .room-head {
            padding: 8px 4px !important;
            text-align: center;
            vertical-align: middle;
            background: linear-gradient(180deg, #eef4ff 0%, #f8fbff 100%);
        }

        .room-head-inner {
            min-height: 86px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            writing-mode: horizontal-tb;
            /* Chế độ viết chuẩn */
            transform: none;
            font-size: 0.82rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            margin: 0 auto;
        }

        .admin-cell {
            height: 94px;
            vertical-align: top;
            padding: 4px !important;
            background: #fcfdff;
        }

        .phong-focus {
            position: relative;
            background: #fff8db !important;
            box-shadow: inset 0 0 0 2px #f59f00;
        }

        .phong-focus-card {
            box-shadow: 0 0 0 3px rgba(245, 159, 0, 0.35), 0 12px 24px rgba(0, 0, 0, 0.12);
        }

        .tkb-card {
            border-radius: 10px;
            padding: 8px 7px;
            color: white;
            height: 100%;
            transition: 0.3s;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }

        .tkb-card::after {
            content: '';
            position: absolute;
            right: -12px;
            bottom: -30px;
            width: 58px;
            height: 58px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.12);
        }

        .tkb-class {
            font-size: 0.82rem;
            font-weight: 700;
            line-height: 1.15;
            margin-bottom: 3px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .tkb-subject {
            font-size: 0.7rem;
            line-height: 1.2;
            opacity: 0.96;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .tkb-teacher {
            font-size: 0.68rem;
            line-height: 1.15;
            opacity: 0.9;
            margin-top: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .tkb-meta {
            margin-top: 5px;
            padding-top: 5px;
            border-top: 1px solid rgba(255, 255, 255, 0.24);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 6px;
            font-size: 0.62rem;
        }

        .tkb-meta strong {
            font-size: 0.72rem;
            font-weight: 700;
        }

        .color-sang {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        }

        .color-chieu {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .color-toi {
            background: linear-gradient(135deg, #2c3e50 0%, #000000 100%);
        }

        /* --- STYLE LƯỚI 7 CỘT (SINH VIÊN) --- */
        .user-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 15px;
        }

        .day-col {
            background: #fff;
            border-radius: 15px;
            min-height: 450px;
            border: 1px solid #edf2f7;
        }

        .day-title {
            background: #6e8efb;
            color: white;
            padding: 10px;
            text-align: center;
            border-radius: 15px 15px 0 0;
            font-weight: 700;
        }

        .user-item-card {
            background: #fff;
            margin: 10px;
            padding: 12px;
            border-radius: 10px;
            border-left: 5px solid #6e8efb;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        }

        @media (max-width: 1200px) {
            .user-grid {
                grid-template-columns: repeat(3, 1fr);
            }

            .table-admin-wrapper {
                overflow-x: auto;
            }

            .admin-tkb-table {
                min-width: 1080px;
            }

            .room-head-inner {
                writing-mode: initial;
                transform: none;
                min-height: auto;
            }
        }

        @media (max-width: 600px) {
            .user-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <%- include('header') %>

        <div class="container-fluid py-5 px-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-dark mb-1">Hệ Thống Lịch Học Khai Trí</h2>
                    <p class="text-muted">Chào <b>
                            <%= user.HoVaTen %>
                        </b> (<%= user.QuyenHan %>). Chúc bạn một ngày tốt lành!</p>
                </div>
                <% if(user.QuyenHan !=='sinhvien' ) { %>
                    <a href="/tkb/dangky" class="main-btn"><i class="fas fa-plus me-2"></i>Đăng Ký Lịch</a>
                    <% } %>
            </div>

            <div class="mb-4">
                <div class="card border-0 shadow-sm" style="border-radius: 15px;">
                    <div class="card-body d-flex align-items-center gap-3">
                        <span class="fw-bold text-dark"><i class="fas fa-calendar-week me-2 text-primary"></i>Chọn
                            Tuần:</span>
                        <div style="min-width: 250px;">
                            <select class="form-select shadow-sm rounded-pill"
                                onchange="location.href='?tuan='+this.value">
                                <% weeks.forEach(function(w) { %>
                                    <option value="<%= w.number %>" <%=currentWeek==w.number ? 'selected' : '' %>>
                                        <%= w.label %>
                                            <%= realCurrentWeek==w.number ? '(Tuần hiện tại)' : '' %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>
                        <small class="text-muted d-none d-md-block">Hệ thống tự động nhận diện tuần học thực tế.</small>
                    </div>
                </div>
            </div>

            <% if(user.QuyenHan==='Admin' || user.QuyenHan==='admin' ) { %>
                <div class="table-admin-wrapper">
                    <table class="table table-bordered admin-tkb-table m-0">
                        <thead class="table-light text-center">
                            <tr>
                                <th class="admin-time-col">Thứ / Buổi</th>
                                <% dsphong.forEach(function(phong) { %>
                                    <th id="phong-<%= phong._id %>" class="room-head" title="<%= phong.TenPhong %>">
                                        <div class="room-head-inner">
                                            <i class="fas fa-door-open text-primary"></i>
                                            <span>
                                                <%= phong.TenPhong %>
                                            </span>
                                        </div>
                                    </th>
                                    <% }); %>
                            </tr>
                        </thead>
                        <tbody>
                            <% cacThu.forEach(function(thu) { %>
                                <% cacBuoi.forEach(function(buoi) { %>
                                    <tr>
                                        <td class="text-center align-middle bg-light">
                                            <div class="fw-bold text-primary">
                                                <%= thu %>
                                            </div>
                                            <small class="badge bg-secondary-subtle text-dark">
                                                <%= buoi %>
                                            </small>
                                        </td>
                                        <% dsphong.forEach(function(phong) { %>
                                            <td class="admin-cell" data-phong-id="<%= phong._id %>">
                                                <% var lich=dsTKB.find(function(i) { return i.Thu===thu &&
                                                    i.CaHoc===buoi && i.PhongHoc &&
                                                    i.PhongHoc._id.toString()===phong._id.toString(); }); %>
                                                    <% if(lich) { %>
                                                        <div class="tkb-card color-<%= lich.CaHoc === 'Sáng'?'sang':(lich.CaHoc === 'Chiều'?'chieu':'toi') %> shadow-sm"
                                                            data-phong-card-id="<%= phong._id %>" data-bs-toggle="modal"
                                                            data-bs-target="#modal<%= lich._id %>"
                                                            style="cursor: pointer;"
                                                            title="<%= (lich.LopHoc ? lich.LopHoc.TenLop : 'N/A') + ' | ' + (lich.MonHoc ? lich.MonHoc.TenMonHoc : 'N/A') + ' | ' + (lich.GiangVien ? lich.GiangVien.HoVaTen : 'N/A') %>">
                                                            <div class="tkb-class">
                                                                <%= lich.LopHoc ? lich.LopHoc.TenLop : 'N/A' %>
                                                            </div>
                                                            <div class="tkb-subject">
                                                                <%= lich.MonHoc?.TenMonHoc %>
                                                            </div>
                                                            <div class="tkb-teacher">
                                                                <i class="fas fa-user-tie me-1"></i>
                                                                <%= lich.GiangVien?.HoVaTen || 'Chưa có GV' %>
                                                            </div>
                                                            <div class="tkb-meta">
                                                                <span><strong>
                                                                        <%= lich.CaHoc %>
                                                                    </strong></span>
                                                                <span>T<%= lich.TietBatDau %>-<%= lich.TietKetThuc %>
                                                                </span>
                                                                <i class="fas fa-eye" style="opacity: 0.7;"></i>
                                                            </div>
                                                        </div>

                                                        <div class="modal fade" id="modal<%= lich._id %>" tabindex="-1"
                                                            aria-hidden="true">
                                                            <div class="modal-dialog modal-dialog-centered">
                                                                <div class="modal-content border-0 shadow-lg"
                                                                    style="border-radius: 20px;">
                                                                    <div class="modal-header border-0 pb-0">
                                                                        <h5 class="fw-bold text-primary"><i
                                                                                class="fas fa-info-circle me-2"></i>Chi
                                                                            Tiết Lịch Học</h5>
                                                                        <button type="button" class="btn-close"
                                                                            data-bs-dismiss="modal"
                                                                            aria-label="Close"></button>
                                                                    </div>
                                                                    <div class="modal-body p-4 text-dark">
                                                                        <div class="mb-3">
                                                                            <label class="text-muted small d-block">Môn
                                                                                học & Lớp</label>
                                                                            <span class="fw-bold fs-5 text-primary">
                                                                                <%= lich.MonHoc?.TenMonHoc %> - <%=
                                                                                        lich.LopHoc?.TenLop %>
                                                                            </span>
                                                                        </div>
                                                                        <div class="row g-3">
                                                                            <div class="col-6">
                                                                                <label
                                                                                    class="text-muted small d-block">Giảng
                                                                                    viên</label>
                                                                                <span class="fw-semibold">
                                                                                    <%= lich.GiangVien?.HoVaTen
                                                                                        || 'Chưa cập nhật' %>
                                                                                </span>
                                                                            </div>
                                                                            <div class="col-6">
                                                                                <label
                                                                                    class="text-muted small d-block">Phòng
                                                                                    học</label>
                                                                                <span class="fw-semibold text-danger">
                                                                                    <%= lich.PhongHoc?.TenPhong %>
                                                                                </span>
                                                                            </div>
                                                                            <div class="col-12">
                                                                                <label
                                                                                    class="text-muted small d-block">Thời
                                                                                    gian</label>
                                                                                <span class="fw-semibold">
                                                                                    <%= lich.Thu %>, <%= lich.CaHoc %>
                                                                                            (Tiết <%= lich.TietBatDau %>
                                                                                                -<%= lich.TietKetThuc %>
                                                                                                    )
                                                                                </span>
                                                                            </div>
                                                                        </div>

                                                                        <div class="d-flex gap-2 mt-4">
                                                                            <button
                                                                                class="btn btn-light rounded-pill flex-grow-1 fw-bold"
                                                                                data-bs-dismiss="modal">Đóng</button>

                                                                            <% if(user.QuyenHan==='Admin' ||
                                                                                user.QuyenHan==='admin' ) { %>
                                                                                <a href="/tkb/sua/<%= lich._id %>"
                                                                                    class="btn btn-primary rounded-pill flex-grow-1 fw-bold">Sửa
                                                                                    lịch</a>
                                                                                <form
                                                                                    action="/tkb/xoa/<%= lich._id %>?_method=DELETE"
                                                                                    method="POST" class="flex-grow-1"
                                                                                    onsubmit="return confirm('Tâm có chắc muốn xóa lịch này không?')">
                                                                                    <button
                                                                                        class="btn btn-outline-danger rounded-pill w-100 fw-bold">Xóa</button>
                                                                                </form>
                                                                                <% } %>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <% } %>
                                            </td>
                                            <% }); %>
                                    </tr>
                                    <% }); %>
                                        <% }); %>
                        </tbody>
                    </table>
                </div>

                <% } else { %>
                    <div class="user-grid">
                        <% cacThu.forEach(function(thu) { %>
                            <div class="day-col">
                                <div class="day-title">
                                    <%= thu %>
                                </div>
                                <div class="day-body">
                                    <% var items=dsTKB.filter(function(i) { return i.Thu===thu; }); if(items.length> 0)
                                        {
                                        items.forEach(function(item) {
                                        %>
                                        <div class="user-item-card">
                                            <div class="fw-bold text-primary">
                                                <%= item.MonHoc?.TenMonHoc %>
                                            </div>
                                            <div class="small fw-semibold mt-1 text-dark">
                                                <i class="fas fa-users-class me-1 text-success"></i>Lớp: <%=
                                                    item.LopHoc?.TenLop || 'N/A' %>
                                            </div>
                                            <div class="small text-muted"><i class="fas fa-clock me-1"></i>Tiết <%=
                                                    item.TietBatDau %>-<%= item.TietKetThuc %>
                                            </div>
                                            <div class="small mt-1"><i
                                                    class="fas fa-map-marker-alt me-1 text-danger"></i>P: <%=
                                                    item.PhongHoc?.TenPhong %>
                                            </div>
                                            <div class="mt-2 pt-1 border-top text-secondary" style="font-size: 0.7rem;">
                                                GV: <%= item.GiangVien?.HoVaTen %>
                                            </div>
                                        </div>
                                        <% }); } else { %>
                                            <div class="text-center mt-5 text-muted opacity-25 small">Trống</div>
                                            <% } %>
                                </div>
                            </div>
                            <% }); %>
                    </div>
                    <% } %>
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var phongId = window.location.hash ? window.location.hash.replace('#phong-', '') : '';
                if (!phongId) return;

                var headerPhong = document.getElementById('phong-' + phongId);
                var oPhong = document.querySelectorAll('[data-phong-id="' + phongId + '"]');
                var theLich = document.querySelector('[data-phong-card-id="' + phongId + '"]');
                var mucTieu = theLich || headerPhong;

                if (headerPhong) {
                    headerPhong.classList.add('phong-focus');
                }

                oPhong.forEach(function (cell) {
                    cell.classList.add('phong-focus');
                });

                if (theLich) {
                    theLich.classList.add('phong-focus-card');
                }

                if (mucTieu) {
                    setTimeout(function () {
                        mucTieu.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'center' });
                    }, 200);
                }
            });
        </script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>