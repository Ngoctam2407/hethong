<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            font-family: 'Quicksand', sans-serif;
            background-color: #f4f7fe;
        }

        .main-btn {
            background: linear-gradient(135deg, #6e8efb, #a777e3);
            border: none;
            color: white;
            padding: 10px 25px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s;
            display: inline-block;
        }

        .main-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(110, 142, 251, 0.4);
            color: white;
        }

        /* --- STYLE MA TRẬN (ADMIN & GIẢNG VIÊN) --- */
        .table-admin-wrapper {
            background: white;
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            overflow-x: auto;
            /* Cho phép cuộn ngang khi quá nhiều phòng */
        }

        .admin-tkb-table {
            min-width: 1200px;
            border-collapse: separate;
            border-spacing: 0;
            table-layout: fixed;
        }

        .admin-tkb-table th,
        .admin-tkb-table td {
            border: 1px solid #e2e8f0 !important;
            padding: 15px !important;
        }

        .admin-buoi-col {
            width: 100px;
            background: #f8fafc !important;
            font-weight: 700;
            text-align: center;
            vertical-align: middle;
            color: #1e293b;
        }

        .thu-head {
            padding: 15px !important;
            text-align: center;
            vertical-align: middle;
            background: #6e8efb !important;
            color: white !important;
            font-weight: 700;
            font-size: 1rem;
        }

        .admin-cell {
            height: auto;
            min-height: 150px;
            vertical-align: top !important;
            background: #ffffff;
        }

        /* --- HOTEL ROOM STYLE --- */
        .room-status-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(65px, 1fr));
            gap: 8px;
        }

        .room-box {
            aspect-ratio: 1/1;
            border-radius: 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 700;
            text-decoration: none !important;
            transition: all 0.2s;
            border: 2px solid #e2e8f0;
            position: relative;
        }

        /* Phòng trống */
        .room-box.is-free {
            background: #f8fafc;
            color: #64748b;
        }

        .room-box.is-free:hover {
            background: #ecfdf5;
            border-color: #10b981;
            color: #059669;
            transform: translateY(-3px);
        }

        /* Phòng đang học */
        .room-box.is-busy {
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            color: white;
            border: none;
            box-shadow: 0 4px 6px rgba(37, 99, 235, 0.2);
        }

        .room-box.is-busy:hover {
            transform: scale(1.1);
            z-index: 10;
            box-shadow: 0 10px 15px rgba(37, 99, 235, 0.3);
        }

        /* Phòng bảo trì */
        .room-box.is-maintenance {
            background: #fff1f2;
            color: #e11d48;
            border-color: #fecdd3;
            cursor: not-allowed;
        }

        .phong-focus {
            box-shadow: 0 0 0 3px #f59f00 !important;
            border-color: #f59f00 !important;
        }

        .room-box-id {
            font-size: 0.6rem;
            opacity: 0.8;
            margin-top: 2px;
        }

        /* --- STYLE LƯỚI 7 CỘT (SINH VIÊN) --- */
        .user-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 15px;
        }

        .day-col {
            background: #fff;
            border-radius: 15px;
            min-height: 450px;
            border: 1px solid #edf2f7;
        }

        .day-title {
            background: #6e8efb;
            color: white;
            padding: 10px;
            text-align: center;
            border-radius: 15px 15px 0 0;
            font-weight: 700;
        }

        .user-item-card {
            background: #fff;
            margin: 10px;
            padding: 12px;
            border-radius: 10px;
            border-left: 5px solid #6e8efb;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        }

        @media (max-width: 1200px) {
            .user-grid {
                grid-template-columns: repeat(3, 1fr);
            }

            .table-admin-wrapper {
                overflow-x: auto;
            }

            .admin-tkb-table {
                min-width: 1080px;
            }

            .room-head-inner {
                writing-mode: initial;
                transform: none;
                min-height: auto;
            }
        }

        @media (max-width: 600px) {
            .user-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <%- include('header') %>

        <div class="container-fluid py-5 px-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-dark mb-1">Hệ Thống Lịch Học Khai Trí</h2>
                    <p class="text-muted">Chào <b>
                            <%= user.HoVaTen %>
                        </b> (<%= user.QuyenHan %>). Chúc bạn một ngày tốt lành!</p>
                </div>
                <% if(user.QuyenHan !=='sinhvien' && currentWeek>= realCurrentWeek) { %>
                    <a href="/tkb/dangky" class="main-btn"><i class="fas fa-plus me-2"></i>Đăng Ký Lịch</a>
                    <% } %>
            </div>

            <div class="mb-4">
                <div class="card border-0 shadow-sm" style="border-radius: 15px;">
                    <div class="card-body d-flex align-items-center gap-3">
                        <span class="fw-bold text-dark"><i class="fas fa-calendar-week me-2 text-primary"></i>Chọn
                            Tuần:</span>
                        <div style="min-width: 250px;">
                            <select class="form-select shadow-sm rounded-pill"
                                onchange="location.href='?tuan='+this.value">
                                <% weeks.forEach(function(w) { %>
                                    <option value="<%= w.number %>" <%=currentWeek==w.number ? 'selected' : '' %>>
                                        <%= w.label %>
                                            <%= realCurrentWeek==w.number ? '(Tuần hiện tại)' : '' %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>
                        <small class="text-muted d-none d-md-block">Hệ thống tự động nhận diện tuần học thực tế.</small>
                    </div>
                </div>
            </div>

            <% if (currentWeek < realCurrentWeek) { %>
                <div class="alert alert-warning border-0 shadow-sm rounded-4 mb-4">
                    <i class="fas fa-history me-2"></i> Bạn đang xem lại dữ liệu của <b>Tuần <%= currentWeek %></b>
                    trong quá khứ. Các chức năng chỉnh sửa đã bị khóa.
                </div>
                <% } %>

                    <% if(user.QuyenHan==='Admin' || user.QuyenHan==='admin' ) { %>
                        <div class="table-admin-wrapper">
                            <table class="table table-bordered admin-tkb-table m-0" id="matrixTable">
                                <thead class="text-center">
                                    <tr>
                                        <th class="admin-buoi-col">Buổi</th>
                                        <% cacThu.forEach(function(thu) { %>
                                            <th class="thu-head">
                                                <%= thu %>
                                            </th>
                                            <% }); %>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% cacBuoi.forEach(function(buoi) { %>
                                        <tr>
                                            <td class="admin-buoi-col">
                                                <%= buoi %>
                                            </td>
                                            <% cacThu.forEach(function(thu) { %>
                                                <td class="admin-cell">
                                                    <div class="room-status-grid">
                                                        <% dsphong.forEach(function(phong) { %>
                                                            <% var lich=dsTKB.find(function(i) { return i.Thu===thu &&
                                                                i.CaHoc===buoi && i.PhongHoc &&
                                                                i.PhongHoc._id.toString()===phong._id.toString(); });
                                                                var statusClass=lich ? 'is-busy' : (phong.KhoaThuCong
                                                                ? 'is-maintenance' : null); if (statusClass) { %>

                                                                <div class="room-box <%= statusClass %>"
                                                                    id="room-<%= phong._id %>-<%= thu %>-<%= buoi %>"
                                                                    data-phong-id="<%= phong._id %>" <% if(lich) { %>
                                                                    data-bs-toggle="modal" data-bs-target="#modal<%=
                                                                        lich._id %>
                                                                        "
                                                                        title="Đang bận: <%= lich.LopHoc?.TenLop %>"
                                                                            <% } else { %>
                                                                                title="Đang bảo trì"
                                                                                <% } %>>
                                                                                    <span class="room-name">
                                                                                        <%= phong.TenPhong %>
                                                                                    </span>
                                                                                    <span class="room-status-text">
                                                                                        <%= lich ? 'BẬN' : 'BẢO TRÌ' %>
                                                                                    </span>
                                                                </div>

                                                                <% if(lich) { %>
                                                                    <!-- Modal chi tiết lịch (Giữ nguyên logic cũ của bạn) -->
                                                                    <div class="modal fade" id="modal<%= lich._id %>"
                                                                        tabindex="-1" aria-hidden="true">
                                                                        <div class="modal-dialog modal-dialog-centered">
                                                                            <div class="modal-content border-0 shadow-lg"
                                                                                style="border-radius: 20px;">
                                                                                <div class="modal-header border-0 pb-0">
                                                                                    <h5 class="fw-bold text-primary"><i
                                                                                            class="fas fa-info-circle me-2"></i>Chi
                                                                                        Tiết Lịch Học</h5>
                                                                                    <button type="button"
                                                                                        class="btn-close"
                                                                                        data-bs-dismiss="modal"></button>
                                                                                </div>
                                                                                <div
                                                                                    class="modal-body p-4 text-dark text-start">
                                                                                    <p><strong>Lớp:</strong>
                                                                                        <%= lich.LopHoc?.TenLop %>
                                                                                    </p>
                                                                                    <p><strong>Môn:</strong>
                                                                                        <%= lich.MonHoc?.TenMonHoc %>
                                                                                    </p>
                                                                                    <p><strong>Giảng viên:</strong>
                                                                                        <%= lich.GiangVien?.HoVaTen %>
                                                                                    </p>
                                                                                    <p><strong>Thời gian:</strong>
                                                                                        <%= lich.Thu %>, <%= lich.CaHoc
                                                                                                %> (Tiết
                                                                                                <%= lich.TietBatDau %>-
                                                                                                    <%= lich.TietKetThuc
                                                                                                        %>)
                                                                                    </p>
                                                                                    <% if (currentWeek>=
                                                                                        realCurrentWeek) { %>
                                                                                        <div class="d-flex gap-2 mt-3">
                                                                                            <a href="/tkb/sua/<%= lich._id %>"
                                                                                                class="btn btn-primary rounded-pill flex-grow-1">Sửa</a>
                                                                                            <a href="/tkb/xoa/<%= lich._id %>"
                                                                                                class="btn btn-outline-danger rounded-pill flex-grow-1"
                                                                                                onclick="return confirm('Xóa lịch này?')">Xóa</a>
                                                                                        </div>
                                                                                        <% } %>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <% } %>
                                                                        <% } %>
                                                                            <% }); %>
                                                    </div>
                                                </td>
                                                <% }); %>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                        </div>

                        <% } else { %>
                            <div class="user-grid">
                                <% cacThu.forEach(function(thu) { %>
                                    <div class="day-col">
                                        <div class="day-title">
                                            <%= thu %>
                                        </div>
                                        <div class="day-body">
                                            <% var items=dsTKB.filter(function(i) { return i.Thu===thu; });
                                                if(items.length> 0)
                                                {
                                                items.forEach(function(item) {
                                                %>
                                                <div class="user-item-card">
                                                    <div class="fw-bold text-primary">
                                                        <%= item.MonHoc?.TenMonHoc %>
                                                    </div>
                                                    <div class="small fw-bold text-danger mt-1">
                                                        <i class="fas fa-calendar-check me-1"></i>Ngày: <%=
                                                            item.NgayHocHienThi %>
                                                    </div>
                                                    <div class="small fw-semibold mt-1 text-dark">
                                                        <i class="fas fa-users-class me-1 text-success"></i>Lớp: <%=
                                                            item.LopHoc?.TenLop || 'N/A' %>
                                                    </div>
                                                    <div class="small text-muted"><i class="fas fa-clock me-1"></i>Tiết
                                                        <%= item.TietBatDau %>-<%= item.TietKetThuc %>
                                                    </div>
                                                    <div class="small mt-1"><i
                                                            class="fas fa-map-marker-alt me-1 text-danger"></i>P: <%=
                                                            item.PhongHoc?.TenPhong %>
                                                    </div>
                                                    <div class="mt-2 pt-1 border-top text-secondary"
                                                        style="font-size: 0.7rem;">
                                                        GV: <%= item.GiangVien?.HoVaTen %>
                                                    </div>
                                                    <% if (user.QuyenHan === 'giangvien') { %>
                                                        <% if (item.HuyTrangThai === 'cho-duyet') { %>
                                                            <div class="badge bg-warning-subtle text-warning mt-2">Đang chờ duyệt hủy/nghỉ</div>
                                                        <% } else if (item.HuyTrangThai !== 'da-duyet') { %>
                                                            <form action="/tkb/yeu-cau-huy/<%= item._id %>" method="POST" class="mt-2" onsubmit="return ganLyDoHuy(this)">
                                                                <input type="hidden" name="LyDoHuy">
                                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill w-100">
                                                                    <i class="fas fa-calendar-xmark me-1"></i>Yêu cầu hủy/nghỉ
                                                                </button>
                                                            </form>
                                                        <% } %>
                                                    <% } %>
                                                </div>
                                                <% }); } else { %>
                                                    <div class="text-center mt-5 text-muted opacity-25 small">Trống
                                                    </div>
                                                    <% } %>
                                        </div>
                                    </div>
                                    <% }); %>
                            </div>
                            <% } %>
        </div>
        <script>
            function ganLyDoHuy(form) {
                const lyDo = prompt('Nhập lý do hủy/nghỉ lịch:');
                if (lyDo === null) return false;
                form.querySelector('input[name="LyDoHuy"]').value = lyDo.trim();
                return confirm('Gửi yêu cầu hủy/nghỉ lịch này cho admin duyệt?');
            }

            document.addEventListener('DOMContentLoaded', function () {
                const phongId = window.location.hash ? window.location.hash.replace('#phong-', '') : '';
                if (!phongId) return;

                const targets = document.querySelectorAll(`[data-phong-id="${phongId}"]`);
                targets.forEach(t => t.classList.add('phong-focus'));

                if (targets.length > 0) {
                    targets[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            });
        </script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
