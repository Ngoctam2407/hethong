<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            font-family: 'Quicksand', sans-serif;
            background-color: #f8f9fa;
        }

        .main-btn {
            background: linear-gradient(135deg, #007bff 0%, #6610f2 100%);
            border: none;
            color: white;
            padding: 10px 30px;
            border-radius: 50px;
            font-weight: 600;
            transition: 0.3s;
            text-decoration: none;
        }

        .main-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(0, 123, 255, 0.3);
            color: white;
        }

        /* LƯỚI THỜI KHÓA BIỂU */
        .calendar-wrapper {
            display: flex;
            flex-direction: column;
            min-width: 900px;
            background: #fff;
            border-radius: 15px;
            overflow: hidden;
        }

        .calendar-header-grid {
            display: grid;
            grid-template-columns: 80px repeat(7, 1fr);
            background: #f1f4f9;
            border-bottom: 2px solid #e9ecef;
        }

        .day-col {
            padding: 15px 0;
            text-align: center;
            color: #007bff;
            font-weight: 700;
            border-right: 1px solid #dee2e6;
        }

        .calendar-body-grid {
            display: grid;
            grid-template-columns: 80px repeat(7, 1fr);
            grid-template-rows: repeat(12, 65px);
            /* 12 tiết học */
            position: relative;
        }

        .time-slot {
            border-right: 1px solid #f1f1f1;
            border-bottom: 1px solid #f1f1f1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            color: #adb5bd;
            font-weight: 600;
        }

        /* THẺ MÔN HỌC - Style giống cái card ở trang chủ của Tâm */
        .tkb-card {
            margin: 3px;
            border-radius: 12px;
            padding: 8px;
            font-size: 0.75rem;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            transition: 0.3s;
            cursor: pointer;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
            border: none;
        }

        .tkb-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
            z-index: 5;
        }

        /* Màu sắc theo buổi (Đồng bộ Gradient) */
        .color-sang {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        }

        .color-chieu {
            background: linear-gradient(135deg, #6610f2 0%, #007bff 100%);
        }

        .color-toi {
            background: linear-gradient(135deg, #434343 0%, #000000 100%);
        }

        .table-card {
            border: none;
            border-radius: 20px;
            background: #ffffff;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            overflow-x: auto;
            /* Để xem được trên điện thoại */
        }
    </style>
</head>

<body>

    <div class="container mt-5 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="fw-bold mb-1" style="font-size: 2.2rem;">Lịch Học <span>Của Tâm</span></h1>
                <p class="text-muted">Dưới đây là thời khóa biểu đã được phê duyệt</p>
            </div>
            <a href="/tkb/dangky" class="main-btn">
                <i class="fas fa-plus-circle me-2"></i>Đăng ký mới
            </a>
        </div>

        <div class="table-card">
            <div class="calendar-wrapper">
                <div class="calendar-header-grid">
                    <div class="day-col" style="background: #f8f9fa;">Tiết</div>
                    <div class="day-col">Thứ 2</div>
                    <div class="day-col">Thứ 3</div>
                    <div class="day-col">Thứ 4</div>
                    <div class="day-col">Thứ 5</div>
                    <div class="day-col">Thứ 6</div>
                    <div class="day-col">Thứ 7</div>
                    <div class="day-col border-right-0">Chủ Nhật</div>
                </div>

                <div class="calendar-body-grid">
                    <% for(let t=1; t <=12; t++) { %>
                        <div class="time-slot" style="grid-column: 1; grid-row: <%= t %>;">
                            T.<%= t %>
                        </div>
                        <% } %>

                            <% const dayToCol={ "Thứ 2" : 2, "Thứ 3" : 3, "Thứ 4" : 4, "Thứ 5" : 5, "Thứ 6" : 6, "Thứ 7"
                                : 7, "Chủ Nhật" : 8 }; dsTKB.forEach(tkb=> {
                                // 2. Lấy số cột từ bảng từ điển phía trên
                                const colIndex = dayToCol[tkb.Thu] || 2;

                                // 3. Tính xem môn này học trong bao nhiêu tiết để thẻ giãn ra (span)
                                const spanTiet = (tkb.TietKetThuc - tkb.TietBatDau) + 1;
                                %>
                                <div class="tkb-card color-<%= tkb.CaHoc === 'Sáng' ? 'sang' : (tkb.CaHoc === 'Chiều' ? 'chieu' : 'toi') %>"
                                    style="grid-column: <%= colIndex %>; grid-row: <%= tkb.TietBatDau %> / span <%= spanTiet %>;">

                                    <div class="fw-bold text-truncate">
                                        <%= tkb.MonHoc.TenMonHoc %>
                                    </div>

                                    <div class="opacity-75" style="font-size: 0.65rem;">
                                        <i class="fas fa-users me-1"></i>
                                        <%= tkb.LopHoc ? tkb.LopHoc.TenLop : 'Chưa rõ lớp' %>
                                    </div>

                                    <div class="opacity-75" style="font-size: 0.65rem;">
                                        <i class="fas fa-map-marker-alt me-1"></i>
                                        <%= tkb.PhongHoc ? tkb.PhongHoc.TenPhong : 'Chưa rõ phòng' %>
                                    </div>

                                    <div class="card-detail-hover">
                                        <small><i class="fas fa-user-tie me-1"></i>
                                            <%= tkb.GiangVien?.HoVaTen %>
                                        </small>
                                        <br>
                                        <small><i class="fas fa-clock me-1"></i> Tiết <%= tkb.TietBatDau %>-
                                                <%= tkb.TietKetThuc %></small>
                                    </div>
                                </div>
                                <% }) %>
                </div>
            </div>
        </div>
    </div>

</body>

</html>