<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <%- include('css') %>

        <style>
            .notif-card {
                border-left: 4px solid #007bff;
                transition: all 0.3s ease;
                cursor: pointer;
            }

            .notif-card:hover {
                background-color: #f8f9fa;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            }

            .notif-card.unread {
                background-color: #e7f3ff;
                border-left-color: #0056b3;
            }

            .notif-card.unread .notif-title {
                font-weight: 700;
                color: #0056b3;
            }

            .notif-card .notif-title {
                font-weight: 600;
                color: #2d3436;
                margin-bottom: 0.5rem;
            }

            .notif-card .notif-content {
                color: #636e72;
                font-size: 0.95rem;
                line-height: 1.5;
            }

            .notif-card .notif-time {
                font-size: 0.75rem;
                color: #95a5a6;
            }

            .notif-type-badge {
                display: inline-block;
                font-size: 0.7rem;
                padding: 0.25rem 0.5rem;
                border-radius: 4px;
                margin-right: 0.5rem;
            }

            .notif-type-lich-moi {
                background-color: #d4edda;
                color: #155724;
            }

            .notif-type-nghi-day {
                background-color: #f8d7da;
                color: #721c24;
            }

            .notif-type-he-thong {
                background-color: #cce5ff;
                color: #004085;
            }

            .empty-notif {
                text-align: center;
                padding: 3rem 1rem;
            }

            .empty-notif i {
                font-size: 3rem;
                color: #dfe6e9;
                margin-bottom: 1rem;
                display: block;
            }

            .notif-actions {
                display: flex;
                gap: 0.5rem;
                margin-top: 0.75rem;
            }

            .notif-actions button {
                font-size: 0.75rem;
                padding: 0.25rem 0.75rem;
            }
        </style>
</head>

<body>
    <%- include('header') %>

        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-lg-9">
                    <div class="mb-4">
                        <a href="/" class="text-decoration-none text-primary fw-600">
                            <i class="fas fa-arrow-left me-2"></i>Trở về trang chủ
                        </a>
                    </div>

                    <div class="bg-white p-4 shadow-sm" style="border-radius: 15px; margin-bottom: 2rem;">
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <div>
                                <h2 class="fw-bold mb-1">
                                    <i class="fas fa-bell me-2 text-info"></i>Thông Báo
                                </h2>
                                <p class="text-muted mb-0">Danh sách tất cả thông báo trong 30 ngày gần đây</p>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-primary rounded-pill" style="font-size: 0.9rem;">
                                    <%= dsThongBao.length %> thông báo
                                </span>
                            </div>
                        </div>

                        <!-- Danh sách thông báo -->
                        <% if (dsThongBao && dsThongBao.length> 0) { %>
                            <div class="notif-list">
                                <% dsThongBao.forEach(function(tb, index) { var loaiMap={ 'lich-moi' : 'Lịch mới'
                                    , 'nghi-day' : 'Nghỉ dạy' , 'he-thong' : 'Hệ thống' }; var thoiGianTao=new
                                    Date(tb.createdAt); var dinh_dang=new Intl.DateTimeFormat('vi-VN', { year: 'numeric'
                                    , month: '2-digit' , day: '2-digit' , hour: '2-digit' , minute: '2-digit' }); %>
                                    <div class="notif-card p-3 mb-3 rounded <%= !tb.DaXem ? 'unread' : '' %>"
                                        data-id="<%= tb._id %>">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div class="flex-grow-1">
                                                <div class="d-flex align-items-center mb-2">
                                                    <% if (tb.LoaiThongBao==='lich-moi' ) { %>
                                                        <span class="notif-type-badge notif-type-lich-moi">
                                                            <i class="fas fa-calendar-plus me-1"></i>
                                                            <%= loaiMap[tb.LoaiThongBao] %>
                                                        </span>
                                                        <% } else if (tb.LoaiThongBao==='nghi-day' ) { %>
                                                            <span class="notif-type-badge notif-type-nghi-day">
                                                                <i class="fas fa-calendar-times me-1"></i>
                                                                <%= loaiMap[tb.LoaiThongBao] %>
                                                            </span>
                                                            <% } else { %>
                                                                <span class="notif-type-badge notif-type-he-thong">
                                                                    <i class="fas fa-info-circle me-1"></i>
                                                                    <%= loaiMap[tb.LoaiThongBao] %>
                                                                </span>
                                                                <% } %>
                                                                    <% if (!tb.DaXem) { %>
                                                                        <span class="badge bg-warning text-dark ms-2"
                                                                            style="font-size: 0.6rem;">Chưa xem</span>
                                                                        <% } %>
                                                </div>
                                                <h5 class="notif-title">
                                                    <%= tb.TieuDe %>
                                                </h5>
                                                <p class="notif-content mb-2">
                                                    <%= tb.NoiDung %>
                                                </p>
                                                <div class="notif-time">
                                                    <i class="fas fa-clock me-1"></i>
                                                    <%= dinh_dang.format(thoiGianTao) %>
                                                </div>
                                            </div>
                                            <div class="ms-3">
                                                <button class="btn btn-sm btn-outline-secondary" type="button"
                                                    onclick="daXemThongBao('<%= tb._id %>', this)"
                                                    title="Đánh dấu đã xem">
                                                    <i class="fas fa-check"></i>
                                                </button>
                                            </div>
                                        </div>
                                        <% if (tb.LienKet) { %>
                                            <div class="notif-actions mt-3 pt-3 border-top">
                                                <a href="<%= tb.LienKet %>" class="btn btn-sm btn-primary"
                                                    onclick="daXemThongBao('<%= tb._id %>')">
                                                    <i class="fas fa-external-link-alt me-1"></i>Xem chi tiết
                                                </a>
                                            </div>
                                            <% } %>
                                    </div>
                                    <% }); %>
                            </div>
                            <% } else { %>
                                <div class="empty-notif">
                                    <i class="fas fa-inbox"></i>
                                    <h5 class="text-muted">Không có thông báo</h5>
                                    <p class="text-muted">Bạn chưa nhận được thông báo nào trong 30 ngày gần đây</p>
                                </div>
                                <% } %>
                    </div>
                </div>
            </div>
        </div>

        <script>
            function daXemThongBao(id, button) {
                fetch('/thongbao/da-xem/' + id, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            var card = document.querySelector('[data-id="' + id + '"]');
                            if (card) {
                                card.classList.remove('unread');
                                // Cập nhật badge số thông báo chưa xem
                                var badge = card.querySelector('.badge.bg-warning');
                                if (badge) {
                                    badge.remove();
                                }
                            }
                            if (button) {
                                button.innerHTML = '<i class="fas fa-check-circle text-success"></i>';
                                button.disabled = true;
                            }
                        }
                    })
                    .catch(err => console.error('Lỗi đánh dấu đã xem:', err));
            }
        </script>
</body>

</html>