<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <%- include('css') %>
        <style>
            body {
                font-family: 'Quicksand', sans-serif;
                background-color: #f4f7f6;
            }

            .table-card {
                background: white;
                border-radius: 20px;
                overflow: hidden;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
                border: none;
            }

            .main-btn {
                background: linear-gradient(135deg, #007bff 0%, #6610f2 100%);
                border: none;
                color: white;
                padding: 10px 25px;
                border-radius: 50px;
                font-weight: 600;
                transition: 0.3s;
            }

            .main-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(102, 16, 242, 0.3);
                color: white;
            }

            .badge-soft {
                padding: 8px 12px;
                border-radius: 10px;
                font-weight: 600;
                font-size: 0.8rem;
            }

            .fw-600 {
                font-weight: 600;
            }
        </style>
</head>

<body>
    <%- include('header') %>

        <div class="container mt-5 mb-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-dark mb-1">Danh sách phòng học</h2>
                    <p class="text-muted mb-0">Quản lý không gian giảng dạy và học tập Edu KT</p>
                </div>
                <% if (dsphong.length>= 12) { %>
                    <button class="btn btn-secondary shadow-sm"
                        style="border-radius: 50px; padding: 10px 25px; cursor: not-allowed;" disabled
                        title="Hệ thống đã đủ 12 phòng cố định theo sơ đồ">
                        <i class="fas fa-lock me-2"></i>Đã đủ 12 phòng
                    </button>
                    <% } else { %>
                        <a href="/phonghoc/them" class="btn main-btn shadow-sm">
                            <i class="fas fa-plus-circle me-2"></i>Thêm phòng học (<%= dsphong.length %>/12)
                        </a>
                        <% } %>
            </div>

            <div class="table-card">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead style="background-color: #f8f9fa;">
                            <tr class="text-secondary">
                                <th class="ps-4 py-3" style="width: 80px;">STT</th>
                                <th class="py-3">Tên Phòng</th>
                                <th class="py-3">Loại Phòng</th>
                                <th class="py-3 text-center">Sức Chứa</th>
                                <th class="py-3 text-center">Trạng Thái</th>
                                <th class="py-3 text-center">Thao Tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% var stt=1; %>
                                <% dsphong.forEach(function(phong) { %>
                                    <tr>
                                        <td class="ps-4 fw-bold text-muted">
                                            <%= stt++ %>
                                        </td>
                                        <td>
                                            <div class="fw-bold text-dark" style="font-size: 1.1rem;">
                                                <i class="fas fa-door-open me-2 text-primary"></i>
                                                <%= phong.TenPhong %>
                                            </div>
                                            <small class="text-muted">
                                                <%= phong.GhiChu || 'Không có mô tả' %>
                                            </small>
                                        </td>
                                        <td>
                                            <span class="px-2 py-1 bg-light rounded text-secondary fw-600"
                                                style="font-size: 0.85em; border: 1px solid #e9ecef;">
                                                <%= phong.LoaiPhong || 'Lý thuyết' %>
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <div class="fw-bold"><i class="fas fa-users me-1 text-muted"></i>
                                                <%= phong.SucChua %>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <% if(phong.TrangThai==1) { %>
                                                <a href="/phonghoc/trangthai/<%= phong._id %>"
                                                    class="badge-soft bg-success-subtle text-success border border-success-subtle text-decoration-none">
                                                    <i class="fas fa-check-circle me-1"></i>Sẵn sàng
                                                </a>
                                                <% } else { %>
                                                    <a href="/phonghoc/trangthai/<%= phong._id %>"
                                                        class="badge-soft bg-danger-subtle text-danger border border-danger-subtle text-decoration-none">
                                                        <i class="fas fa-tools me-1"></i>Bảo trì
                                                    </a>
                                                    <% } %>
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a href="/phonghoc/sua/<%= phong._id %>"
                                                    class="btn btn-sm btn-light rounded-circle text-primary border shadow-sm"
                                                    title="Chỉnh sửa">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a href="/phonghoc/xoa/<%= phong._id %>"
                                                    class="btn btn-sm btn-light rounded-circle text-danger border shadow-sm"
                                                    onclick="return confirm('Tâm ơi, em có chắc chắn muốn xóa phòng này không?')"
                                                    title="Xóa">
                                                    <i class="fas fa-trash-alt"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <%- include('footer') %>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>