<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <%- include('css') %>
        <style>
            body {
                font-family: 'Quicksand', sans-serif;
                background-color: #f4f7f6;
            }

            .table-card {
                background: white;
                border-radius: 20px;
                overflow: hidden;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
                border: none;
            }

            .main-btn {
                background: linear-gradient(135deg, #007bff 0%, #6610f2 100%);
                border: none;
                color: white;
                padding: 10px 25px;
                border-radius: 50px;
                font-weight: 600;
                transition: 0.3s;
            }

            .main-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(102, 16, 242, 0.3);
                color: white;
            }

            .badge-soft {
                padding: 8px 12px;
                border-radius: 10px;
                font-weight: 600;
                font-size: 0.8rem;
            }

            .fw-600 {
                font-weight: 600;
            }
        </style>
</head>

<body>
    <%- include('header') %>

        <div class="container mt-5 mb-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-dark mb-1">Danh sách phòng học</h2>
                    <p class="text-muted mb-0">
                        Trạng thái được tính theo ngày hôm nay và tiết đang diễn ra<%= tietHienTai ? ' (tiết ' + tietHienTai + ')' : '' %>.
                    </p>
                </div>
                <a href="/phonghoc/them" class="btn main-btn shadow-sm">
                    <i class="fas fa-plus-circle me-2"></i>Thêm phòng học (<%= dsphong.length %>)
                </a>
            </div>

            <div class="table-card">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead style="background-color: #f8f9fa;">
                            <tr class="text-secondary">
                                <th class="ps-4 py-3" style="width: 80px;">STT</th>
                                <th class="py-3">Tên phòng</th>
                                <th class="py-3">Loại phòng</th>
                                <th class="py-3 text-center">Sức chứa</th>
                                <th class="py-3 text-center">Trạng thái</th>
                                <th class="py-3 text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% var stt=1; %>
                                <% dsphong.forEach(function(phong) { %>
                                    <tr>
                                        <td class="ps-4 fw-bold text-muted">
                                            <%= stt++ %>
                                        </td>
                                        <td>
                                            <div class="fw-bold text-dark" style="font-size: 1.1rem;">
                                                <i class="fas fa-door-open me-2 text-primary"></i>
                                                <%= phong.TenPhong %>
                                            </div>
                                            <small class="text-muted">
                                                <%= phong.GhiChu || 'Không có mô tả' %>
                                            </small>
                                        </td>
                                        <td>
                                            <span class="px-2 py-1 bg-light rounded text-secondary fw-600"
                                                style="font-size: 0.85em; border: 1px solid #e9ecef;">
                                                <%= phong.LoaiPhong || 'Lý thuyết' %>
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <div class="fw-bold"><i class="fas fa-users me-1 text-muted"></i>
                                                <%= phong.SucChua %>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <% if (phong.TrangThaiHienThi==='bao-tri' ) { %>
                                                <span
                                                    class="badge-soft bg-warning-subtle text-warning border border-warning-subtle">
                                                    <i class="fas fa-screwdriver-wrench me-1"></i>Bảo trì
                                                </span>
                                                <% } else if (phong.TrangThaiHienThi==='dang-su-dung' ) { %>
                                                    <span
                                                        class="badge-soft bg-danger-subtle text-danger border border-danger-subtle">
                                                        <i class="fas fa-chalkboard-teacher me-1"></i>Đang sử dụng
                                                    </span>
                                                    <% if (phong.LichDangSuDung) { %>
                                                        <div class="small text-muted mt-2">
                                                            <div><%= phong.LichDangSuDung.LopHoc ? phong.LichDangSuDung.LopHoc.TenLop : 'Lớp học' %> - <%= phong.LichDangSuDung.MonHoc ? phong.LichDangSuDung.MonHoc.TenMonHoc : 'Môn học' %></div>
                                                            <div><%= phong.LichDangSuDung.GiangVien ? phong.LichDangSuDung.GiangVien.HoVaTen : 'Giảng viên' %>, tiết <%= phong.LichDangSuDung.TietBatDau %>-<%= phong.LichDangSuDung.TietKetThuc %></div>
                                                        </div>
                                                    <% } %>
                                                    <% } else { %>
                                                        <span
                                                            class="badge-soft bg-success-subtle text-success border border-success-subtle">
                                                            <i class="fas fa-check-circle me-1"></i>Trống
                                                        </span>
                                                        <% } %>
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a href="/tkb#phong-<%= phong._id %>"
                                                    class="btn btn-sm btn-light rounded-circle text-info border shadow-sm"
                                                    title="Xem chi tiết">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="/phonghoc/sua/<%= phong._id %>"
                                                    class="btn btn-sm btn-light rounded-circle text-primary border shadow-sm"
                                                    title="Chỉnh sửa">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a href="/phonghoc/trangthai/<%= phong._id %>"
                                                    class="btn btn-sm btn-light rounded-circle <%= phong.KhoaThuCong ? 'text-warning' : 'text-success' %> border shadow-sm"
                                                    title="<%= phong.KhoaThuCong ? 'Mở lại phòng' : 'Khóa phòng để bảo trì' %>">
                                                    <i
                                                        class="fas <%= phong.KhoaThuCong ? 'fa-lock-open' : 'fa-screwdriver-wrench' %>"></i>
                                                </a>
                                                <a href="/phonghoc/xoa/<%= phong._id %>"
                                                    class="btn btn-sm btn-light rounded-circle text-danger border shadow-sm"
                                                    onclick="return confirm('Bạn có chắc muốn xóa phòng này không?')"
                                                    title="Xóa">
                                                    <i class="fas fa-trash-alt"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
